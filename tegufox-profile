#!/usr/bin/env python3
"""
Tegufox Profile Manager CLI

Command-line tool for managing Tegufox browser profiles.

Commands:
    list                  List all profiles
    show <name>          Show profile details
    validate <name>      Validate profile
    create <name>        Create new profile
    template <browser>   Create from template
    clone <src> <dst>    Clone profile
    merge <base> <overlay> <name>  Merge profiles
    delete <name>        Delete profile
    export <names...>    Export profiles
    import <file>        Import profiles
    search <query>       Search profiles
    stats                Show statistics

Author: Tegufox Browser Toolkit
Date: April 14, 2026
Phase: 1 - Week 3 Day 14
License: MIT
"""

import sys
import argparse
import json
from pathlib import Path
from typing import List, Optional

# Add parent directory to path
sys.path.insert(0, str(Path(__file__).parent))

from profile_manager import ProfileManager, ValidationLevel, BROWSER_TEMPLATES
from consistency_engine import ConsistencyEngine, default_rules
from fingerprint_registry import FingerprintRegistry, DEFAULT_DB_PATH
from generator_v2 import generate_profile, MARKET_DISTRIBUTIONS


def cmd_list(args):
    """List all profiles"""
    manager = ProfileManager(args.profiles_dir)
    
    profiles = manager.list(args.pattern)
    
    if not profiles:
        print("No profiles found.")
        return
    
    print(f"Profiles ({len(profiles)}):")
    for name in profiles:
        # Load and show brief info
        try:
            profile = manager.load(name)
            desc = profile.get("description", "")
            print(f"  {name:30s} {desc}")
        except Exception as e:
            print(f"  {name:30s} [Error: {e}]")


def cmd_show(args):
    """Show profile details"""
    manager = ProfileManager(args.profiles_dir)
    
    try:
        profile = manager.load(args.name)
        
        if args.json:
            print(json.dumps(profile, indent=2))
        else:
            print(f"Profile: {args.name}")
            print("=" * 60)
            print(f"Name: {profile.get('name', 'N/A')}")
            print(f"Description: {profile.get('description', 'N/A')}")
            print(f"Created: {profile.get('created', 'N/A')}")
            print(f"Version: {profile.get('version', 'N/A')}")
            
            if "navigator" in profile:
                nav = profile["navigator"]
                print(f"\nNavigator:")
                print(f"  User-Agent: {nav.get('userAgent', 'N/A')}")
                print(f"  Platform: {nav.get('platform', 'N/A')}")
                print(f"  Vendor: {nav.get('vendor', 'N/A')}")
            
            if "screen" in profile:
                screen = profile["screen"]
                print(f"\nScreen:")
                print(f"  Size: {screen.get('width', 0)}x{screen.get('height', 0)}")
            
            if "dns_config" in profile:
                dns = profile["dns_config"]
                print(f"\nDNS:")
                print(f"  Enabled: {dns.get('enabled', False)}")
                print(f"  Provider: {dns.get('provider', 'N/A')}")
            
            if "fingerprints" in profile:
                fp = profile["fingerprints"]
                print(f"\nFingerprints:")
                print(f"  JA3: {fp.get('ja3', 'N/A')}")
                print(f"  JA4: {fp.get('ja4', 'N/A')}")
    
    except FileNotFoundError:
        print(f"Error: Profile not found: {args.name}")
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


def cmd_validate(args):
    """Validate profile"""
    manager = ProfileManager(args.profiles_dir)
    
    try:
        profile = manager.load(args.name)
        
        # Determine validation level
        level_map = {
            "basic": ValidationLevel.BASIC,
            "standard": ValidationLevel.STANDARD,
            "strict": ValidationLevel.STRICT,
        }
        level = level_map.get(args.level, ValidationLevel.STANDARD)
        
        result = manager.validate(profile, level)
        
        print(f"Profile: {args.name}")
        print("=" * 60)
        print(f"Valid: {'✓ YES' if result.valid else '✗ NO'}")
        print(f"Score: {result.score:.2f} / 1.00")
        print(f"Level: {result.level.value}")
        
        if result.errors:
            print(f"\nErrors ({len(result.errors)}):")
            for error in result.errors:
                print(f"  ✗ {error}")
        
        if result.warnings:
            print(f"\nWarnings ({len(result.warnings)}):")
            for warning in result.warnings:
                print(f"  ⚠ {warning}")
        
        if result.valid:
            print("\n✓ Profile is valid!")
        else:
            print("\n✗ Profile has validation errors")
            sys.exit(1)
    
    except FileNotFoundError:
        print(f"Error: Profile not found: {args.name}")
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


def cmd_create(args):
    """Create new profile"""
    manager = ProfileManager(args.profiles_dir)
    
    if manager.exists(args.name) and not args.force:
        print(f"Error: Profile already exists: {args.name}")
        print("Use --force to overwrite")
        sys.exit(1)
    
    # Create profile
    profile = manager.create(
        name=args.name,
        description=args.description or f"Custom profile: {args.name}",
    )
    
    # Save
    saved_path = manager.save(profile, args.name)
    
    print(f"✓ Created profile: {args.name}")
    print(f"  Path: {saved_path}")
    
    if args.edit:
        print(f"\nEdit the profile: {saved_path}")


def cmd_template(args):
    """Create profile from template"""
    manager = ProfileManager(args.profiles_dir)
    
    if manager.exists(args.name) and not args.force:
        print(f"Error: Profile already exists: {args.name}")
        print("Use --force to overwrite")
        sys.exit(1)
    
    try:
        if getattr(args, 'weighted', False):
            import random
            profile = generate_profile(manager, rng=random.Random(), doh_provider=args.doh_provider)
        else:
            profile = manager.generate_template(
                browser=args.browser,
                os=args.os or "windows",
                screen_width=args.width or 1920,
                screen_height=args.height or 1080,
                doh_provider=args.doh_provider,
            )
        
        # Update name
        profile["name"] = args.name
        
        # Save
        saved_path = manager.save(profile, args.name)
        
        print(f"✓ Created profile from template: {args.browser}")
        print(f"  Name: {args.name}")
        print(f"  Path: {saved_path}")
        
        # Validate
        result = manager.validate(profile, ValidationLevel.STANDARD)
        print(f"  Validation score: {result.score:.2f}")
    
    except ValueError as e:
        print(f"Error: {e}")
        print(f"\nAvailable templates: {', '.join(BROWSER_TEMPLATES.keys())}")
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


def cmd_clone(args):
    """Clone profile"""
    manager = ProfileManager(args.profiles_dir)
    
    if manager.exists(args.destination) and not args.force:
        print(f"Error: Destination profile already exists: {args.destination}")
        print("Use --force to overwrite")
        sys.exit(1)
    
    try:
        profile = manager.clone(args.source, args.destination)
        saved_path = manager.save(profile, args.destination)
        
        print(f"✓ Cloned profile")
        print(f"  From: {args.source}")
        print(f"  To: {args.destination}")
        print(f"  Path: {saved_path}")
    
    except FileNotFoundError:
        print(f"Error: Source profile not found: {args.source}")
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


def cmd_merge(args):
    """Merge profiles"""
    manager = ProfileManager(args.profiles_dir)
    
    if manager.exists(args.name) and not args.force:
        print(f"Error: Output profile already exists: {args.name}")
        print("Use --force to overwrite")
        sys.exit(1)
    
    try:
        profile = manager.merge(args.base, args.overlay, args.name)
        saved_path = manager.save(profile, args.name)
        
        print(f"✓ Merged profiles")
        print(f"  Base: {args.base}")
        print(f"  Overlay: {args.overlay}")
        print(f"  Output: {args.name}")
        print(f"  Path: {saved_path}")
    
    except FileNotFoundError as e:
        print(f"Error: {e}")
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


def cmd_delete(args):
    """Delete profile"""
    manager = ProfileManager(args.profiles_dir)
    
    if not manager.exists(args.name):
        print(f"Error: Profile not found: {args.name}")
        sys.exit(1)
    
    if not args.yes:
        response = input(f"Delete profile '{args.name}'? [y/N] ")
        if response.lower() != 'y':
            print("Cancelled")
            return
    
    deleted = manager.delete(args.name)
    
    if deleted:
        print(f"✓ Deleted profile: {args.name}")
    else:
        print(f"Error: Failed to delete profile: {args.name}")
        sys.exit(1)


def cmd_export(args):
    """Export profiles"""
    manager = ProfileManager(args.profiles_dir)
    
    try:
        manager.export_bulk(args.names, args.output)
        print(f"✓ Exported {len(args.names)} profiles")
        print(f"  Output: {args.output}")
    
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


def cmd_import(args):
    """Import profiles"""
    manager = ProfileManager(args.profiles_dir)
    
    try:
        imported = manager.import_bulk(args.file, overwrite=args.force)
        print(f"✓ Imported {len(imported)} profiles:")
        for name in imported:
            print(f"  - {name}")
    
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


def cmd_search(args):
    """Search profiles"""
    manager = ProfileManager(args.profiles_dir)
    
    results = manager.search(args.query)
    
    if not results:
        print(f"No profiles found matching: {args.query}")
        return
    
    print(f"Found {len(results)} profile(s):")
    for name in results:
        try:
            profile = manager.load(name)
            desc = profile.get("description", "")
            print(f"  {name:30s} {desc}")
        except Exception:
            print(f"  {name}")


def cmd_score(args):
    """Evaluate profile through the cross-layer consistency engine"""
    manager = ProfileManager(args.profiles_dir)

    try:
        profile = manager.load(args.name)
    except FileNotFoundError:
        print(f"Error: Profile not found: {args.name}")
        sys.exit(1)

    registry = None
    if not args.no_registry:
        try:
            registry = FingerprintRegistry()
        except Exception as e:
            print(f"Warning: could not open fingerprint registry ({e}); skipping anti-correlation.")

    engine = ConsistencyEngine(default_rules(), registry=registry)

    try:
        report = engine.evaluate(profile)
    except NotImplementedError as e:
        print(f"Error: {e}")
        print("The GPU rule is intentionally a user hot-spot. Fill in the TODO USER block in consistency_engine.py.")
        if registry:
            registry.close()
        sys.exit(2)

    if args.json:
        print(json.dumps(report.to_dict(), indent=2))
    else:
        print(f"Profile: {args.name}")
        print("=" * 60)
        print(report.summary())

    if registry:
        registry.close()

    if not report.passed:
        sys.exit(1)


def cmd_collisions(args):
    """Show fingerprint collisions for a profile"""
    manager = ProfileManager(args.profiles_dir)

    try:
        profile = manager.load(args.name)
    except FileNotFoundError:
        print(f"Error: Profile not found: {args.name}")
        sys.exit(1)

    with FingerprintRegistry() as registry:
        collisions = registry.find_collisions_for_profile(profile)
        print(f"Profile: {args.name}")
        print("=" * 60)
        if collisions:
            print(f"Collisions ({len(collisions)}):")
            for name in collisions:
                print(f"  ! {name}")
            sys.exit(1)
        else:
            print("No fingerprint collisions found.")
            print(f"(Database: {DEFAULT_DB_PATH})")


def cmd_stats(args):
    """Show statistics"""
    manager = ProfileManager(args.profiles_dir)
    
    stats = manager.get_stats()
    
    print("Profile Statistics")
    print("=" * 60)
    print(f"Total profiles: {stats['total_profiles']}")
    print(f"\nBrowser distribution:")
    for browser, count in stats['browser_counts'].items():
        print(f"  {browser:10s} {count:3d}")
    print(f"\nValidation:")
    print(f"  Valid:   {stats['validation']['valid']}")
    print(f"  Invalid: {stats['validation']['invalid']}")
    print(f"  Average score: {stats['validation']['avg_score']:.2f}")


def main():
    """Main CLI entry point"""
    parser = argparse.ArgumentParser(
        description="Tegufox Profile Manager - Manage browser profiles",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    
    parser.add_argument(
        "--profiles-dir",
        default="profiles",
        help="Profiles directory (default: profiles/)"
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Command")
    
    # list
    parser_list = subparsers.add_parser("list", help="List profiles")
    parser_list.add_argument("--pattern", help="Glob pattern filter")
    parser_list.set_defaults(func=cmd_list)
    
    # show
    parser_show = subparsers.add_parser("show", help="Show profile details")
    parser_show.add_argument("name", help="Profile name")
    parser_show.add_argument("--json", action="store_true", help="Output as JSON")
    parser_show.set_defaults(func=cmd_show)
    
    # validate
    parser_validate = subparsers.add_parser("validate", help="Validate profile")
    parser_validate.add_argument("name", help="Profile name")
    parser_validate.add_argument(
        "--level",
        choices=["basic", "standard", "strict"],
        default="standard",
        help="Validation level"
    )
    parser_validate.set_defaults(func=cmd_validate)

    # score (consistency engine)
    parser_score = subparsers.add_parser(
        "score",
        help="Evaluate cross-layer consistency (6 rules + anti-correlation)"
    )
    parser_score.add_argument("name", help="Profile name")
    parser_score.add_argument("--json", action="store_true", help="Machine-readable output")
    parser_score.add_argument(
        "--no-registry",
        action="store_true",
        help="Skip anti-correlation DB check"
    )
    parser_score.set_defaults(func=cmd_score)

    # collisions
    parser_collisions = subparsers.add_parser(
        "collisions",
        help="Show fingerprint collisions for a profile"
    )
    parser_collisions.add_argument("name", help="Profile name")
    parser_collisions.set_defaults(func=cmd_collisions)

    # create
    parser_create = subparsers.add_parser("create", help="Create new profile")
    parser_create.add_argument("name", help="Profile name")
    parser_create.add_argument("--description", help="Profile description")
    parser_create.add_argument("--force", action="store_true", help="Overwrite existing")
    parser_create.add_argument("--edit", action="store_true", help="Open in editor")
    parser_create.set_defaults(func=cmd_create)
    
    # template
    parser_template = subparsers.add_parser("template", help="Create from template")
    parser_template.add_argument(
        "browser",
        choices=list(BROWSER_TEMPLATES.keys()),
        help="Browser template"
    )
    parser_template.add_argument("name", help="Profile name")
    parser_template.add_argument("--os", help="Operating system (windows/macos/linux)")
    parser_template.add_argument("--width", type=int, help="Screen width")
    parser_template.add_argument("--height", type=int, help="Screen height")
    parser_template.add_argument("--doh-provider", help="DoH provider")
    parser_template.add_argument("--force", action="store_true", help="Overwrite existing")
    parser_template.add_argument(
        "--weighted",
        action="store_true",
        help="Sample browser/OS from market distribution (ignores browser arg)"
    )
    parser_template.set_defaults(func=cmd_template)
    
    # clone
    parser_clone = subparsers.add_parser("clone", help="Clone profile")
    parser_clone.add_argument("source", help="Source profile")
    parser_clone.add_argument("destination", help="Destination profile")
    parser_clone.add_argument("--force", action="store_true", help="Overwrite existing")
    parser_clone.set_defaults(func=cmd_clone)
    
    # merge
    parser_merge = subparsers.add_parser("merge", help="Merge profiles")
    parser_merge.add_argument("base", help="Base profile")
    parser_merge.add_argument("overlay", help="Overlay profile")
    parser_merge.add_argument("name", help="Output profile name")
    parser_merge.add_argument("--force", action="store_true", help="Overwrite existing")
    parser_merge.set_defaults(func=cmd_merge)
    
    # delete
    parser_delete = subparsers.add_parser("delete", help="Delete profile")
    parser_delete.add_argument("name", help="Profile name")
    parser_delete.add_argument("-y", "--yes", action="store_true", help="Skip confirmation")
    parser_delete.set_defaults(func=cmd_delete)
    
    # export
    parser_export = subparsers.add_parser("export", help="Export profiles")
    parser_export.add_argument("names", nargs="+", help="Profile names")
    parser_export.add_argument("-o", "--output", required=True, help="Output file")
    parser_export.set_defaults(func=cmd_export)
    
    # import
    parser_import = subparsers.add_parser("import", help="Import profiles")
    parser_import.add_argument("file", help="Input file")
    parser_import.add_argument("--force", action="store_true", help="Overwrite existing")
    parser_import.set_defaults(func=cmd_import)
    
    # search
    parser_search = subparsers.add_parser("search", help="Search profiles")
    parser_search.add_argument("query", help="Search query")
    parser_search.set_defaults(func=cmd_search)
    
    # stats
    parser_stats = subparsers.add_parser("stats", help="Show statistics")
    parser_stats.set_defaults(func=cmd_stats)
    
    # Parse args
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        sys.exit(1)
    
    # Run command
    args.func(args)


if __name__ == "__main__":
    main()
