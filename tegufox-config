def generate_random_seed():
    """Generate random seed for canvas/audio"""
    import random
    return random.randint(1000000, 9999999999)


def validate_json_schema(profile: Dict[str, Any]) -> Tuple[bool, List[str]]:
    """Validate profile against JSON schema"""
    errors = []
    
    # Check required fields
    for field in PROFILE_SCHEMA['required']:
        if field not in profile:
            errors.append(f"Missing required field: {field}")
    
    if 'config' in profile:
        config = profile['config']
        schema_props = PROFILE_SCHEMA['properties']['config']['properties']
        
        # Validate each config key
        for key, value in config.items():
            if key in schema_props:
                expected = schema_props[key]
                
                # Type validation
                if 'type' in expected:
                    expected_types = expected['type'] if isinstance(expected['type'], list) else [expected['type']]
                    value_type = type(value).__name__
                    
                    # Map Python types to JSON schema types
                    type_map = {'str': 'string', 'int': 'integer', 'float': 'number', 'bool': 'boolean', 'NoneType': 'null'}
                    json_type = type_map.get(value_type, value_type)
                    
                    if json_type not in expected_types:
                        errors.append(f"{key}: expected {expected['type']}, got {json_type}")
                
                # Range validation
                if 'minimum' in expected and isinstance(value, (int, float)):
                    if value < expected['minimum']:
                        errors.append(f"{key}: value {value} is below minimum {expected['minimum']}")
                
                if 'maximum' in expected and isinstance(value, (int, float)):
                    if value > expected['maximum']:
                        errors.append(f"{key}: value {value} exceeds maximum {expected['maximum']}")
                
                # Enum validation
                if 'enum' in expected and value not in expected['enum']:
                    errors.append(f"{key}: value {value} not in allowed values {expected['enum']}")
    
    return len(errors) == 0, errors


def merge_profiles(base_file: str, override_file: str, output_file: str, strategy: str = 'override'):
    """
    Merge two profiles together
    
    Strategies:
    - override: Override profile takes precedence (default)
    - base: Base profile takes precedence
    - combine: Combine both (base + unique keys from override)
    """
    
    print(f"🔀 Merging profiles with strategy: {strategy}")
    print(f"   Base: {base_file}")
    print(f"   Override: {override_file}")
    
    # Load profiles
    with open(base_file) as f:
        base_profile = json.load(f)
    
    with open(override_file) as f:
        override_profile = json.load(f)
    
    # Create merged profile
    merged = base_profile.copy()
    
    if strategy == 'override':
        # Override profile takes precedence
        merged['config'] = {**base_profile.get('config', {}), **override_profile.get('config', {})}
        merged['name'] = override_profile.get('name', base_profile.get('name'))
        merged['description'] = f"Merged: {base_profile.get('name')} + {override_profile.get('name')}"
    
    elif strategy == 'base':
        # Base profile takes precedence
        override_config = override_profile.get('config', {})
        base_config = base_profile.get('config', {})
        merged['config'] = {**override_config, **base_config}
        merged['description'] = f"Merged: {base_profile.get('name')} (base priority)"
    
    elif strategy == 'combine':
        # Combine unique keys
        base_config = base_profile.get('config', {})
        override_config = override_profile.get('config', {})
        
        merged['config'] = base_config.copy()
        for key, value in override_config.items():
            if key not in merged['config']:
                merged['config'][key] = value
        
        merged['description'] = f"Combined: {base_profile.get('name')} + {override_profile.get('name')}"
    
    # Update metadata
    merged['created'] = datetime.now().isoformat()
    merged['metadata'] = {
        'version': '2.0',
        'tegufox_version': '0.2.0',
        'merged_from': [
            base_profile.get('name'),
            override_profile.get('name')
        ],
        'merge_strategy': strategy
    }
    
    # Save merged profile
    with open(output_file, 'w') as f:
        json.dump(merged, f, indent=2)
    
    print(f"✅ Merged profile saved to: {output_file}")
    print(f"📊 Config keys: {len(merged['config'])}")
    print(f"   From base: {len(base_profile.get('config', {}))}")
    print(f"   From override: {len(override_profile.get('config', {}))}")
    
    return output_file


def compare_profiles(profile1_file: str, profile2_file: str, show_values: bool = False):
    """Compare two profiles and show differences"""
    
    print(f"🔍 Comparing profiles:")
    print(f"   Profile 1: {profile1_file}")
    print(f"   Profile 2: {profile2_file}\n")
    
    # Load profiles
    with open(profile1_file) as f:
        profile1 = json.load(f)
    
    with open(profile2_file) as f:
        profile2 = json.load(f)
    
    config1 = profile1.get('config', {})
    config2 = profile2.get('config', {})
    
    # Find differences
    all_keys = set(config1.keys()) | set(config2.keys())
    only_in_1 = set(config1.keys()) - set(config2.keys())
    only_in_2 = set(config2.keys()) - set(config1.keys())
    common_keys = set(config1.keys()) & set(config2.keys())
    
    different_values = {}
    for key in common_keys:
        if config1[key] != config2[key]:
            different_values[key] = (config1[key], config2[key])
    
    # Print results
    print(f"📊 Summary:")
    print(f"   Total unique keys: {len(all_keys)}")
    print(f"   Common keys: {len(common_keys)}")
    print(f"   Only in profile 1: {len(only_in_1)}")
    print(f"   Only in profile 2: {len(only_in_2)}")
    print(f"   Different values: {len(different_values)}")
    
    if only_in_1:
        print(f"\n📦 Only in {profile1.get('name', 'Profile 1')}:")
        for key in sorted(only_in_1):
            if show_values:
                print(f"   {key}: {config1[key]}")
            else:
                print(f"   {key}")
    
    if only_in_2:
        print(f"\n📦 Only in {profile2.get('name', 'Profile 2')}:")
        for key in sorted(only_in_2):
            if show_values:
                print(f"   {key}: {config2[key]}")
            else:
                print(f"   {key}")
    
    if different_values:
        print(f"\n⚠️  Different values:")
        for key in sorted(different_values.keys()):
            val1, val2 = different_values[key]
            print(f"   {key}:")
            print(f"     Profile 1: {val1}")
            print(f"     Profile 2: {val2}")
    
    if not only_in_1 and not only_in_2 and not different_values:
        print(f"\n✅ Profiles are identical!")
    
    return {
        'total_keys': len(all_keys),
        'common_keys': len(common_keys),
        'only_in_1': len(only_in_1),
        'only_in_2': len(only_in_2),
        'different_values': len(different_values)
    }


def create_profile(platform, name, output_dir):
    """Create a new profile from template"""
    
    if platform not in PLATFORM_TEMPLATES:
        print(f"❌ Unknown platform: {platform}")
        print(f"Available platforms: {', '.join(PLATFORM_TEMPLATES.keys())}")
        sys.exit(1)
    
    template = PLATFORM_TEMPLATES[platform]
    config = template['config'].copy()
    
    # Generate random seeds
    if 'canvas:seed' in config and config['canvas:seed'] is None:
        config['canvas:seed'] = generate_random_seed()
    if 'audio:seed' in config and config['audio:seed'] is None:
        config['audio:seed'] = generate_random_seed()
    
    # Create profile metadata
    profile = {
        'name': name,
        'platform': platform,
        'created': datetime.now().isoformat(),
        'description': template['desc'],
        'config': config,
        'metadata': {
            'version': '1.0',
            'tegufox_version': '0.1.0'
        }
    }
    
    # Save profile
    output_path = Path(output_dir)
    output_path.mkdir(parents=True, exist_ok=True)
    
    profile_file = output_path / f"{name}.json"
    with open(profile_file, 'w') as f:
        json.dump(profile, f, indent=2)
    
    print(f"✅ Created profile: {profile_file}")
    print(f"📝 Platform: {platform}")
    print(f"📝 Description: {template['desc']}")
    print(f"\nConfiguration preview:")
    print(json.dumps(config, indent=2))
    
    return profile_file


def validate_profile(profile_file):
    """Validate profile configuration"""
    
    print(f"🔍 Validating profile: {profile_file}")
    
    if not Path(profile_file).exists():
        print(f"❌ Profile file not found")
        sys.exit(1)
    
    with open(profile_file) as f:
        profile = json.load(f)
    
    # JSON Schema validation
    schema_valid, schema_errors = validate_json_schema(profile)
    
    if schema_errors:
        print("\n❌ Schema validation errors:")
        for error in schema_errors:
            print(f"  - {error}")
        if not schema_valid:
            sys.exit(1)
    
    config = profile.get('config', {})
    warnings = []
    
    # Consistency checks
    platform = config.get('navigator.platform')
    user_agent = config.get('navigator.userAgent', '')
    
    if platform == 'Win32' and 'Windows' not in user_agent:
        warnings.append("Platform is Win32 but userAgent doesn't mention Windows")
    
    if platform == 'MacIntel' and 'Macintosh' not in user_agent:
        warnings.append("Platform is MacIntel but userAgent doesn't mention Macintosh")
    
    # Check GPU/OS correlation
    webgl_vendor = config.get('webGl:vendor', '')
    if platform == 'MacIntel' and 'Apple' not in webgl_vendor:
        warnings.append("macOS platform should typically have Apple GPU")
    
    if platform == 'Win32' and 'Apple' in webgl_vendor:
        warnings.append("Windows platform shouldn't have Apple GPU")
    
    # Check screen dimensions
    screen_width = config.get('screen.width')
    screen_height = config.get('screen.height')
    if screen_width and screen_height:
        aspect_ratio = screen_width / screen_height
        common_ratios = [16/9, 16/10, 21/9, 4/3, 3/2]
        if not any(abs(aspect_ratio - ratio) < 0.1 for ratio in common_ratios):
            warnings.append(f"Unusual screen aspect ratio: {aspect_ratio:.2f}")
    
    # Check timezone and locale correlation
    timezone = config.get('timezone', '')
    locale = config.get('locale', '')
    
    if timezone and locale:
        # US timezones should have en-US locale
        if 'America/' in timezone and locale != 'en-US':
            warnings.append(f"Timezone {timezone} typically uses en-US locale, got {locale}")
    
    # Check hardware consistency
    cores = config.get('navigator.hardwareConcurrency', 0)
    if cores:
        if cores > 32:
            warnings.append(f"Very high CPU core count: {cores} (unusual for consumer hardware)")
        if cores == 1:
            warnings.append("Single core CPU is very rare in modern systems")
    
    # Print results
    print(f"\n✅ Profile structure valid")
    print(f"📊 Configuration keys: {len(config)}")
    
    if warnings:
        print(f"\n⚠️  Warnings ({len(warnings)}):")
        for warning in warnings:
            print(f"  - {warning}")
    else:
        print(f"\n✅ No consistency warnings")
    
    return len(schema_errors) == 0


def test_consistency(profile_file):
    """Test configuration consistency across page loads"""
    
    print(f"🧪 Testing configuration consistency")
    print(f"Profile: {profile_file}")
    
    # This would require running actual browser
    # For now, just validate the config
    return validate_profile(profile_file)


def export_profile(profile_file, output_file=None):
    """Export profile for use with Camoufox"""
    
    with open(profile_file) as f:
        profile = json.load(f)
    
    # Extract just the config part for Camoufox
    config = profile.get('config', {})
    
    if output_file:
        with open(output_file, 'w') as f:
            json.dump(config, f, indent=2)
        print(f"✅ Exported config to: {output_file}")
    else:
        print(json.dumps(config, indent=2))


def list_profiles(directory):
    """List all profiles in directory"""
    
    profile_dir = Path(directory)
    if not profile_dir.exists():
        print(f"❌ Directory not found: {directory}")
        return
    
    profiles = list(profile_dir.glob("*.json"))
    
    if not profiles:
        print(f"No profiles found in {directory}")
        return
    
    print(f"🦊 Profiles in {directory}:\n")
    
    for profile_file in profiles:
        with open(profile_file) as f:
            try:
                profile = json.load(f)
                name = profile.get('name', profile_file.stem)
                platform = profile.get('platform', 'unknown')
                desc = profile.get('description', 'No description')
                created = profile.get('created', 'Unknown')
                
                print(f"📦 {name}")
                print(f"   Platform: {platform}")
                print(f"   Description: {desc}")
                print(f"   Created: {created}")
                print(f"   File: {profile_file}")
                print()
            except json.JSONDecodeError:
                print(f"⚠️  {profile_file.name} - Invalid JSON")
                print()


def show_templates():
    """Show available profile templates"""
    
    print("🦊 Available Profile Templates\n")
    
    for platform, template in PLATFORM_TEMPLATES.items():
        print(f"📦 {platform}")
        print(f"   Description: {template['desc']}")
        print(f"   Config keys: {len(template['config'])}")
        print()


def main():
    print_logo()
    
    parser = argparse.ArgumentParser(
        description='Tegufox Configuration Manager v2.0 - Manage browser profiles',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='''
Examples:
  # Create eBay seller profile
  %(prog)s create --platform ebay-seller --name my-ebay-account
  
  # Validate profile with schema checks
  %(prog)s validate profiles/my-ebay-account.json
  
  # Merge two profiles (override strategy)
  %(prog)s merge profiles/base.json profiles/override.json --output merged.json
  
  # Compare two profiles
  %(prog)s compare profiles/profile1.json profiles/profile2.json --show-values
  
  # List all profiles
  %(prog)s list
  
  # Show available templates
  %(prog)s templates
  
  # Export profile for use
  %(prog)s export profiles/my-ebay-account.json --output config.json
'''
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Commands')
    
    # Create command
    create_parser = subparsers.add_parser('create', help='Create new profile')
    create_parser.add_argument('--platform', required=True,
                              choices=PLATFORM_TEMPLATES.keys(),
                              help='Platform template')
    create_parser.add_argument('--name', required=True,
                              help='Profile name')
    create_parser.add_argument('--output-dir', default='profiles',
                              help='Output directory (default: profiles/)')
    
    # Validate command
    validate_parser = subparsers.add_parser('validate', help='Validate profile')
    validate_parser.add_argument('profile_file', help='Profile file to validate')
    
    # Merge command
    merge_parser = subparsers.add_parser('merge', help='Merge two profiles')
    merge_parser.add_argument('base_file', help='Base profile file')
    merge_parser.add_argument('override_file', help='Override profile file')
    merge_parser.add_argument('--output', required=True, help='Output file for merged profile')
    merge_parser.add_argument('--strategy', choices=['override', 'base', 'combine'],
                             default='override',
                             help='Merge strategy (default: override)')
    
    # Compare command
    compare_parser = subparsers.add_parser('compare', help='Compare two profiles')
    compare_parser.add_argument('profile1', help='First profile file')
    compare_parser.add_argument('profile2', help='Second profile file')
    compare_parser.add_argument('--show-values', action='store_true',
                               help='Show actual values in comparison')
    
    # Test consistency command
    test_parser = subparsers.add_parser('test-consistency',
                                       help='Test configuration consistency')
    test_parser.add_argument('profile_file', help='Profile file to test')
    
    # Export command
    export_parser = subparsers.add_parser('export', help='Export profile config')
    export_parser.add_argument('profile_file', help='Profile file to export')
    export_parser.add_argument('--output', help='Output file (default: stdout)')
    
    # List command
    list_parser = subparsers.add_parser('list', help='List all profiles')
    list_parser.add_argument('--directory', default='profiles',
                            help='Profiles directory (default: profiles/)')
    
    # Templates command
    templates_parser = subparsers.add_parser('templates',
                                            help='Show available templates')
    
    args = parser.parse_args()
    
    if args.command == 'create':
        create_profile(args.platform, args.name, args.output_dir)
    elif args.command == 'validate':
        validate_profile(args.profile_file)
    elif args.command == 'merge':
        merge_profiles(args.base_file, args.override_file, args.output, args.strategy)
    elif args.command == 'compare':
        compare_profiles(args.profile1, args.profile2, args.show_values)
    elif args.command == 'test-consistency':
        test_consistency(args.profile_file)
    elif args.command == 'export':
        export_profile(args.profile_file, args.output)
    elif args.command == 'list':
        list_profiles(args.directory)
    elif args.command == 'templates':
        show_templates()
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
