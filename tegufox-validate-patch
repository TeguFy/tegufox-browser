#!/usr/bin/env python3
"""
Tegufox Patch Validator
Validates patch files before applying to Firefox source

Phase 1 - Week 1: Patch validation tool
"""

import sys
import os
import re
import json
from pathlib import Path
from typing import Dict, List, Tuple, Optional

# ANSI color codes
class Colors:
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    RED = '\033[91m'
    BOLD = '\033[1m'
    UNDERLINE = '\033[4m'
    END = '\033[0m'

def print_logo():
    """Print Tegufox ASCII logo banner"""
    logo = f"""
{Colors.HEADER}{Colors.BOLD}
   ╔════════════════════════════════════════════════════════╗
   ║              🦎 TEGUFOX BROWSER TOOLKIT 🔥             ║
   ║           Advanced Anti-Detect Browser Tools           ║
   ╚════════════════════════════════════════════════════════╝
{Colors.END}"""
    print(logo)

def print_header(text: str):
    """Print colored header"""
    print(f"\n{Colors.HEADER}{Colors.BOLD}{'='*60}{Colors.END}")
    print(f"{Colors.HEADER}{Colors.BOLD}{text.center(60)}{Colors.END}")
    print(f"{Colors.HEADER}{Colors.BOLD}{'='*60}{Colors.END}\n")

def print_success(text: str):
    """Print success message"""
    print(f"{Colors.GREEN}✅ {text}{Colors.END}")

def print_error(text: str):
    """Print error message"""
    print(f"{Colors.RED}❌ {text}{Colors.END}")

def print_warning(text: str):
    """Print warning message"""
    print(f"{Colors.YELLOW}⚠️  {text}{Colors.END}")

def print_info(text: str):
    """Print info message"""
    print(f"{Colors.CYAN}ℹ️  {text}{Colors.END}")


class PatchValidator:
    """Validates Tegufox patch files"""
    
    def __init__(self, patch_path: str):
        self.patch_path = Path(patch_path)
        self.patch_name = self.patch_path.stem
        self.errors: List[str] = []
        self.warnings: List[str] = []
        self.info: List[str] = []
        self.patch_content: str = ""
        self.metadata: Optional[Dict] = None
        
    def validate(self) -> bool:
        """Run all validations. Returns True if valid."""
        print_header(f"VALIDATING: {self.patch_name}")
        
        # Check file exists
        if not self.patch_path.exists():
            print_error(f"Patch file not found: {self.patch_path}")
            return False
        
        # Read patch content
        with open(self.patch_path, 'r') as f:
            self.patch_content = f.read()
        
        print_info(f"File size: {len(self.patch_content)} bytes")
        
        # Run validations
        self._validate_syntax()
        self._validate_headers()
        self._validate_maskconfig_usage()
        self._validate_config_keys()
        self._validate_mozbuild()
        self._validate_metadata()
        self._check_duplicates()
        
        # Print results
        self._print_results()
        
        return len(self.errors) == 0
    
    def _validate_syntax(self):
        """Validate unified diff syntax"""
        print(f"\n{Colors.BOLD}[1/7] Syntax Validation{Colors.END}")
        
        # Check for diff header
        if not re.search(r'^diff --git', self.patch_content, re.MULTILINE):
            self.errors.append("Missing diff header (diff --git)")
            return
        
        # Check for file markers
        if not re.search(r'^---', self.patch_content, re.MULTILINE):
            self.errors.append("Missing '---' file marker")
        if not re.search(r'^\+\+\+', self.patch_content, re.MULTILINE):
            self.errors.append("Missing '+++' file marker")
        
        # Check for hunks
        hunks = re.findall(r'^@@.*@@', self.patch_content, re.MULTILINE)
        if not hunks:
            self.errors.append("No hunks found (@@ markers)")
        else:
            self.info.append(f"Found {len(hunks)} hunk(s)")
        
        # Check for changes
        additions = len(re.findall(r'^\+[^+]', self.patch_content, re.MULTILINE))
        deletions = len(re.findall(r'^-[^-]', self.patch_content, re.MULTILINE))
        
        if additions == 0 and deletions == 0:
            self.warnings.append("No code changes found")
        else:
            self.info.append(f"Changes: +{additions} -{deletions} lines")
        
        if not self.errors:
            print_success("Syntax valid")
    
    def _validate_headers(self):
        """Validate patch headers"""
        print(f"\n{Colors.BOLD}[2/7] Header Validation{Colors.END}")
        
        # Check for Tegufox comment header
        if "# Tegufox Custom Patch" not in self.patch_content:
            self.warnings.append("Missing Tegufox header comment")
        
        # Check for generation timestamp
        if not re.search(r'# Generated: \d{4}-\d{2}-\d{2}', self.patch_content):
            self.warnings.append("Missing or invalid generation timestamp")
        
        # Check for pattern type
        if not re.search(r'# Pattern:', self.patch_content):
            self.warnings.append("Missing pattern type in header")
        
        # Check for config key(s)
        if not re.search(r'# Config key', self.patch_content):
            self.warnings.append("Missing config key in header")
        
        if not self.errors:
            print_success("Headers valid")
    
    def _validate_maskconfig_usage(self):
        """Validate MaskConfig API usage"""
        print(f"\n{Colors.BOLD}[3/7] MaskConfig Usage Validation{Colors.END}")
        
        # Check for MaskConfig include
        if '#include "MaskConfig.hpp"' not in self.patch_content:
            self.errors.append("Missing MaskConfig.hpp include")
            return
        
        # Valid MaskConfig methods
        valid_methods = [
            'GetString', 'GetInt32', 'GetUint32', 'GetUint64', 
            'GetDouble', 'GetBool', 'CheckBool', 'GetStringList',
            'GetRect', 'GetInt32Rect', 'GetDoubleRect', 'GetNested'
        ]
        
        # Find MaskConfig usage
        maskconfig_calls = re.findall(
            r'MaskConfig::(\w+)\s*\(',
            self.patch_content
        )
        
        if not maskconfig_calls:
            self.warnings.append("No MaskConfig API calls found")
        else:
            self.info.append(f"Found {len(maskconfig_calls)} MaskConfig call(s)")
            
            # Check for invalid methods
            for method in maskconfig_calls:
                if method not in valid_methods:
                    self.errors.append(f"Invalid MaskConfig method: {method}")
        
        # Check for value() usage
        if 'value()' not in self.patch_content and maskconfig_calls:
            self.warnings.append("MaskConfig used but .value() not found")
        
        if not self.errors:
            print_success("MaskConfig usage valid")
    
    def _validate_config_keys(self):
        """Validate config key naming conventions"""
        print(f"\n{Colors.BOLD}[4/7] Config Key Validation{Colors.END}")
        
        # Extract config keys from MaskConfig calls
        # Match strings in GetX("key") or GetNested("parent", "child")
        keys = re.findall(
            r'MaskConfig::\w+\s*\(\s*"([^"]+)"',
            self.patch_content
        )
        
        if not keys:
            self.warnings.append("No config keys found in patch")
            return
        
        self.info.append(f"Found {len(keys)} config key(s)")
        
        for key in keys:
            # Check naming convention
            has_dot = '.' in key
            has_colon = ':' in key
            
            if has_dot and has_colon:
                self.warnings.append(f"Key '{key}' mixes dots and colons")
            elif has_dot:
                # Browser API style (navigator.userAgent)
                self.info.append(f"Browser API key: {key}")
            elif has_colon:
                # Custom feature style (canvas:seed)
                self.info.append(f"Custom feature key: {key}")
            else:
                self.warnings.append(f"Key '{key}' has no separator (. or :)")
        
        print_success("Config keys checked")
    
    def _validate_mozbuild(self):
        """Validate moz.build modifications"""
        print(f"\n{Colors.BOLD}[5/7] moz.build Validation{Colors.END}")
        
        # Check for moz.build diff
        if 'diff --git a/' not in self.patch_content:
            self.errors.append("Invalid diff format")
            return
        
        mozbuild_diffs = re.findall(
            r'diff --git a/(.*?/moz\.build)',
            self.patch_content
        )
        
        if not mozbuild_diffs:
            self.errors.append("No moz.build modification found")
            return
        
        self.info.append(f"Found {len(mozbuild_diffs)} moz.build change(s)")
        
        # Check for LOCAL_INCLUDES
        if 'LOCAL_INCLUDES += ["/camoucfg"]' not in self.patch_content:
            self.errors.append("Missing LOCAL_INCLUDES += [\"/camoucfg\"]")
        
        if not self.errors:
            print_success("moz.build modifications valid")
    
    def _validate_metadata(self):
        """Validate metadata JSON file"""
        print(f"\n{Colors.BOLD}[6/7] Metadata Validation{Colors.END}")
        
        metadata_path = self.patch_path.with_suffix('.json')
        
        if not metadata_path.exists():
            self.warnings.append(f"No metadata file found: {metadata_path.name}")
            return
        
        try:
            with open(metadata_path, 'r') as f:
                self.metadata = json.load(f)
            
            # Check required fields
            required_fields = ['name', 'pattern', 'file_path', 'created', 'config']
            for field in required_fields:
                if field not in self.metadata:
                    self.warnings.append(f"Metadata missing '{field}' field")
            
            # Check name consistency
            if self.metadata.get('name') != self.patch_name:
                self.warnings.append(
                    f"Name mismatch: metadata='{self.metadata.get('name')}' "
                    f"file='{self.patch_name}'"
                )
            
            print_success("Metadata valid")
            
        except json.JSONDecodeError as e:
            self.errors.append(f"Invalid JSON in metadata: {e}")
        except Exception as e:
            self.warnings.append(f"Could not read metadata: {e}")
    
    def _check_duplicates(self):
        """Check for duplicate patches"""
        print(f"\n{Colors.BOLD}[7/7] Duplicate Check{Colors.END}")
        
        patches_dir = self.patch_path.parent
        
        # Get target file from patch
        file_matches = re.findall(
            r'diff --git a/(.*?) b/',
            self.patch_content
        )
        
        if not file_matches:
            self.warnings.append("Could not extract target files")
            return
        
        target_files = set(file_matches)
        self.info.append(f"Modifies {len(target_files)} file(s)")
        
        # Check other patches
        duplicates = []
        for other_patch in patches_dir.glob('*.patch'):
            if other_patch == self.patch_path:
                continue
            
            try:
                with open(other_patch, 'r') as f:
                    other_content = f.read()
                
                other_files = set(re.findall(
                    r'diff --git a/(.*?) b/',
                    other_content
                ))
                
                # Check for overlapping files
                overlap = target_files & other_files
                if overlap:
                    duplicates.append((other_patch.name, overlap))
            except:
                pass
        
        if duplicates:
            for other_name, overlap in duplicates:
                files_str = ', '.join(overlap)
                self.warnings.append(
                    f"Overlaps with '{other_name}': {files_str}"
                )
        else:
            print_success("No duplicates found")
    
    def _print_results(self):
        """Print validation summary"""
        print_header("VALIDATION RESULTS")
        
        # Print info messages
        if self.info:
            print(f"\n{Colors.BOLD}Information:{Colors.END}")
            for msg in self.info:
                print_info(msg)
        
        # Print warnings
        if self.warnings:
            print(f"\n{Colors.BOLD}Warnings ({len(self.warnings)}):{Colors.END}")
            for msg in self.warnings:
                print_warning(msg)
        
        # Print errors
        if self.errors:
            print(f"\n{Colors.BOLD}Errors ({len(self.errors)}):{Colors.END}")
            for msg in self.errors:
                print_error(msg)
        
        # Final verdict
        print()
        if self.errors:
            print_error(f"VALIDATION FAILED: {len(self.errors)} error(s)")
            return False
        elif self.warnings:
            print_warning(f"VALIDATION PASSED with {len(self.warnings)} warning(s)")
            return True
        else:
            print_success("VALIDATION PASSED: No issues found!")
            return True


def main():
    """Main validation flow"""
    
    print_logo()
    
    if len(sys.argv) < 2:
        print_header("TEGUFOX PATCH VALIDATOR")
        print(f"{Colors.BOLD}Usage:{Colors.END}")
        print(f"  {sys.argv[0]} <patch-file>")
        print(f"  {sys.argv[0]} patches/my-patch.patch")
        print()
        print(f"{Colors.BOLD}Validate all patches:{Colors.END}")
        print(f"  {sys.argv[0]} --all")
        print()
        return 1
    
    # Validate all patches
    if sys.argv[1] == '--all':
        patches_dir = Path('patches')
        if not patches_dir.exists():
            print_error("patches/ directory not found")
            return 1
        
        patches = list(patches_dir.glob('*.patch'))
        if not patches:
            print_error("No patches found in patches/")
            return 1
        
        print_header(f"VALIDATING {len(patches)} PATCHES")
        
        results = []
        for patch_file in sorted(patches):
            validator = PatchValidator(str(patch_file))
            valid = validator.validate()
            results.append((patch_file.name, valid, len(validator.errors), len(validator.warnings)))
            print()
        
        # Summary
        print_header("SUMMARY")
        
        passed = sum(1 for _, valid, _, _ in results if valid)
        failed = len(results) - passed
        
        print(f"\n{Colors.BOLD}Results:{Colors.END}")
        for name, valid, errors, warnings in results:
            status = f"{Colors.GREEN}✅ PASS" if valid else f"{Colors.RED}❌ FAIL"
            issues = f"({errors} errors, {warnings} warnings)" if (errors or warnings) else ""
            print(f"  {status}{Colors.END} {name} {issues}")
        
        print(f"\n{Colors.BOLD}Total:{Colors.END}")
        print(f"  Passed: {Colors.GREEN}{passed}{Colors.END}")
        print(f"  Failed: {Colors.RED}{failed}{Colors.END}")
        print()
        
        return 0 if failed == 0 else 1
    
    # Validate single patch
    patch_file = sys.argv[1]
    validator = PatchValidator(patch_file)
    valid = validator.validate()
    
    return 0 if valid else 1


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        print(f"\n\n{Colors.YELLOW}Cancelled by user{Colors.END}")
        sys.exit(1)
    except Exception as e:
        print_error(f"Unexpected error: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)
