#!/usr/bin/env python3
"""
Tegufox Patch Generator CLI
Creates C++ patch templates for Camoufox with MaskConfig integration
"""

import argparse
import os
import sys
from pathlib import Path
from datetime import datetime


PATCH_TYPES = {
    'fingerprint': {
        'desc': 'Fingerprinting protection patch',
        'example_files': [
            'dom/base/nsGlobalWindowInner.cpp',
            'dom/canvas/CanvasRenderingContext2D.cpp'
        ]
    },
    'behavior': {
        'desc': 'Behavioral simulation patch',
        'example_files': [
            'dom/events/EventStateManager.cpp',
            'widget/nsBaseWidget.cpp'
        ]
    },
    'network': {
        'desc': 'Network/protocol level patch',
        'example_files': [
            'netwerk/protocol/http/nsHttpChannel.cpp',
            'security/manager/ssl/nsNSSIOLayer.cpp'
        ]
    },
    'webgl': {
        'desc': 'WebGL spoofing patch',
        'example_files': [
            'dom/canvas/WebGLContext.cpp',
            'dom/canvas/WebGLContextGL.cpp'
        ]
    }
}


def create_patch_template(name, patch_type, target_file, description):
    """Generate patch template with MaskConfig integration"""
    
    template = f'''diff --git a/{target_file} b/{target_file}
index xxxxxxxxxx..yyyyyyyyyy 100644
--- a/{target_file}
+++ b/{target_file}
@@ -1,6 +1,7 @@
 /* -*- Mode: C++; tab-width: 8; indent-tabs-mode: nil; c-basic-offset: 2 -*- */
 /* vim: set ts=8 sts=2 et sw=2 tw=80: */
 /* This Source Code Form is subject to the terms of the Mozilla Public
  * License, v. 2.0. If a copy of the MPL was not distributed with this
  * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
 
+#include "MaskConfig.hpp"
 
 // TODO: Add your patch implementation here
 // Example MaskConfig usage:
 //
 // if (auto value = MaskConfig::GetDouble("{name}:parameter"))
 //     return value.value();
 //
 // Available MaskConfig functions:
 // - GetString(key) -> std::optional<std::string>
 // - GetDouble(key) -> std::optional<double>
 // - GetUint32(key) -> std::optional<uint32_t>
 // - GetInt32(key) -> std::optional<int32_t>
 // - GetBool(key) -> std::optional<bool>
 // - CheckBool(key) -> bool (default false)
'''

    # Add moz.build modification
    mozbuild_file = str(Path(target_file).parent / 'moz.build')
    mozbuild_patch = f'''
diff --git a/{mozbuild_file} b/{mozbuild_file}
index xxxxxxxxxx..yyyyyyyyyy 100644
--- a/{mozbuild_file}
+++ b/{mozbuild_file}
@@ -1,3 +1,6 @@
+# Tegufox patch: {name}
+LOCAL_INCLUDES += ["/camoucfg"]
+
 # -*- Mode: python; indent-tabs-mode: nil; tab-width: 40 -*-
 # vim: set filetype=python:
'''
    
    full_patch = template + mozbuild_patch
    
    return full_patch


