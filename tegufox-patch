def main():
    parser = argparse.ArgumentParser(
        description='Tegufox Patch Generator - Create C++ patches with MaskConfig integration',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='''
Examples:
  # Create fingerprinting patch
  %(prog)s create --name canvas-v2 --type fingerprint \\
      --file dom/canvas/CanvasRenderingContext2D.cpp \\
      --desc "Enhanced canvas fingerprint protection"
  
  # Create behavioral patch
  %(prog)s create --name mouse-neuromotor --type behavior \\
      --file dom/events/EventStateManager.cpp \\
      --desc "Neuromotor mouse movement simulation"

Available patch types:
''' + '\n'.join(f"  {k}: {v['desc']}" for k, v in PATCH_TYPES.items())
    )
    
    subparsers = parser.add_subparsers(dest='command', help='Commands')
    
    # Create command
    create_parser = subparsers.add_parser('create', help='Create new patch template')
    create_parser.add_argument('--name', required=True, help='Patch name (e.g., canvas-v2)')
    create_parser.add_argument('--type', required=True, choices=PATCH_TYPES.keys(),
                              help='Patch type')
    create_parser.add_argument('--file', required=True, help='Target Firefox source file')
    create_parser.add_argument('--desc', required=True, help='Patch description')
    create_parser.add_argument('--output-dir', default='patches',
                              help='Output directory (default: patches/)')
    
    # List command
    list_parser = subparsers.add_parser('list', help='List available patch types')
    
    # Validate command
    validate_parser = subparsers.add_parser('validate', help='Validate patch syntax')
    validate_parser.add_argument('patch_file', help='Patch file to validate')
    
    args = parser.parse_args()
    
    if args.command == 'create':
        create_patch(args)
    elif args.command == 'list':
        list_types()
    elif args.command == 'validate':
        validate_patch(args)
    else:
        parser.print_help()


def create_patch(args):
    """Create patch files"""
    
    print(f"🦊 Tegufox Patch Generator")
    print(f"={'='*60}")
    print(f"Creating patch: {args.name}")
    print(f"Type: {args.type} - {PATCH_TYPES[args.type]['desc']}")
    print(f"Target file: {args.file}")
    print(f"{'='*60}\n")
    
    # Create output directory
    output_dir = Path(args.output_dir)
    output_dir.mkdir(parents=True, exist_ok=True)
    
    # Generate patch file
    patch_content = create_patch_template(args.name, args.type, args.file, args.desc)
    patch_file = output_dir / f"{args.name}.patch"
    
    with open(patch_file, 'w') as f:
        f.write(patch_content)
    
    print(f"✅ Created patch file: {patch_file}")
    
    # Generate metadata file
    metadata_content = create_patch_metadata(args.name, args.type, args.file, args.desc)
    metadata_file = output_dir / f"{args.name}.md"
    
    with open(metadata_file, 'w') as f:
        f.write(metadata_content)
    
    print(f"✅ Created metadata file: {metadata_file}")
    
    # Generate test stub
    test_content = create_test_stub(args.name, args.type)
    test_dir = Path('tests') / args.type
    test_dir.mkdir(parents=True, exist_ok=True)
    test_file = test_dir / f"test_{args.name.replace('-', '_')}.py"
    
    with open(test_file, 'w') as f:
        f.write(test_content)
    
    print(f"✅ Created test file: {test_file}")
    
    print(f"\n📝 Next steps:")
    print(f"1. Edit {patch_file} to implement your patch")
    print(f"2. Update {metadata_file} with MaskConfig keys")
    print(f"3. Implement test in {test_file}")
    print(f"4. Apply patch: cd camoufox-source && git apply ../{patch_file}")
    print(f"5. Build: cd camoufox-source && ./mach build")
    print(f"6. Test: python {test_file}")


