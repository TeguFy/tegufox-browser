def list_types():
    """List available patch types"""
    
    print("🦊 Tegufox Patch Types\n")
    
    for patch_type, info in PATCH_TYPES.items():
        print(f"📦 {patch_type}")
        print(f"   Description: {info['desc']}")
        print(f"   Example files:")
        for file in info['example_files']:
            print(f"      - {file}")
        print()


def validate_patch(args):
    """Validate patch syntax"""
    
    patch_file = Path(args.patch_file)
    
    if not patch_file.exists():
        print(f"❌ Patch file not found: {patch_file}")
        sys.exit(1)
    
    print(f"🔍 Validating patch: {patch_file}")
    
    with open(patch_file) as f:
        content = f.read()
    
    # Basic validation
    checks = [
        ('Has diff header', content.startswith('diff --git')),
        ('Has file paths', '---' in content and '+++' in content),
        ('Has change markers', '@@' in content),
        ('Has MaskConfig include', '#include "MaskConfig.hpp"' in content),
        ('Has moz.build modification', 'LOCAL_INCLUDES += ["/camoucfg"]' in content),
    ]
    
    all_passed = True
    for check_name, passed in checks:
        status = "✅" if passed else "❌"
        print(f"{status} {check_name}")
        if not passed:
            all_passed = False
    
    if all_passed:
        print(f"\n✅ Patch validation passed")
    else:
        print(f"\n❌ Patch validation failed")
        sys.exit(1)


if __name__ == "__main__":
    main()
