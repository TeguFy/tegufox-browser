        print_error(f"Pattern {pattern_num} not implemented")
        return 1
    
    # Show preview
    print_header("GENERATED PATCH")
    print(patch_content)
    
    # Confirm save
    print()
    save = get_input("Save this patch? (y/n)", "y")
    
    if save.lower() != 'y':
        print_warning("Patch not saved")
        return 0
    
    # Create patches directory if needed
    patches_dir = Path("patches")
    patches_dir.mkdir(exist_ok=True)
    
    # Generate filename
    filename = f"{config['patch_name']}.patch"
    filepath = patches_dir / filename
    
    # Save patch
    with open(filepath, 'w') as f:
        f.write(f"# Tegufox Custom Patch\n")
        f.write(f"# Generated: {datetime.now().isoformat()}\n")
        f.write(f"# Pattern: {pattern_info['name']}\n")
        # Handle both single config_key and multiple config_keys
        if 'config_key' in config:
            f.write(f"# Config key: {config['config_key']}\n")
        elif 'config_keys' in config:
            f.write(f"# Config keys: {config['config_keys']}\n")
        f.write(f"#\n")
        f.write(patch_content)
    
    print_success(f"Patch saved to: {filepath}")
    
    # Create metadata file
    metadata_file = patches_dir / f"{config['patch_name']}.json"
    import json
    
    # Prepare metadata
    metadata = {
        "name": config['patch_name'],
        "pattern": pattern_info['name'],
        "file_path": config['file_path'],
        "created": datetime.now().isoformat(),
        "config": config
    }
    
    # Add config key(s) to metadata
    if 'config_key' in config:
        metadata['config_key'] = config['config_key']
    elif 'config_keys' in config:
        metadata['config_keys'] = config['config_keys']
    
    with open(metadata_file, 'w') as f:
        json.dump(metadata, f, indent=2)
    
    print_success(f"Metadata saved to: {metadata_file}")
    
    # Next steps
    print(f"\n{Colors.BOLD}Next steps:{Colors.END}")
    print(f"1. Review the patch: {Colors.CYAN}cat {filepath}{Colors.END}")
    print(f"2. Test apply: {Colors.CYAN}cd /path/to/firefox && patch -p1 --dry-run < {filepath.absolute()}{Colors.END}")
    print(f"3. Apply for real: {Colors.CYAN}patch -p1 < {filepath.absolute()}{Colors.END}")
    print(f"4. Build Firefox with the patch")
    
    return 0


