def select_pattern() -> Tuple[str, Dict]:
    """Interactive pattern selection"""
    print_header("TEGUFOX PATCH GENERATOR")
    
    print(f"{Colors.BOLD}Select a patch pattern:{Colors.END}\n")
    
    for key, pattern in PATCH_PATTERNS.items():
        print(f"{Colors.CYAN}[{key}]{Colors.END} {Colors.BOLD}{pattern['name']}{Colors.END}")
        print(f"    {pattern['description']}")
        print(f"    {Colors.YELLOW}Complexity:{Colors.END} {pattern['complexity']}")
        print(f"    {Colors.YELLOW}Example:{Colors.END} {pattern['example']}\n")
    
    while True:
        choice = input(f"{Colors.BOLD}Enter pattern number (1-6): {Colors.END}").strip()
        if choice in PATCH_PATTERNS:
            pattern = PATCH_PATTERNS[choice]
            print_success(f"Selected: {pattern['name']}")
            return choice, pattern
        print_error("Invalid choice. Please enter 1-6.")


def get_input(prompt: str, default: Optional[str] = None, required: bool = True) -> str:
    """Get user input with optional default"""
    if default:
        prompt = f"{prompt} [{default}]: "
    else:
        prompt = f"{prompt}: "
    
    while True:
        value = input(f"{Colors.BOLD}{prompt}{Colors.END}").strip()
        
        if value:
            return value
        elif default:
            return default
        elif not required:
            return ""
        else:
            print_error("This field is required.")


def select_type(prompt: str) -> str:
    """Select MaskConfig type"""
    print(f"\n{Colors.BOLD}Available types:{Colors.END}")
    types_list = list(MASKCONFIG_TYPES.keys())
    for i, type_name in enumerate(types_list, 1):
        print(f"  {Colors.CYAN}[{i}]{Colors.END} {type_name} → MaskConfig::{MASKCONFIG_TYPES[type_name]}()")
    
    while True:
        choice = input(f"{Colors.BOLD}{prompt} (1-{len(types_list)}): {Colors.END}").strip()
        try:
            idx = int(choice) - 1
            if 0 <= idx < len(types_list):
                type_name = types_list[idx]
                print_success(f"Selected: {type_name}")
                return type_name
        except ValueError:
            pass
        print_error(f"Invalid choice. Please enter 1-{len(types_list)}.")


def validate_config_key(key: str) -> bool:
    """Validate config key format"""
    # Should be: word.word or word:word
    pattern = r'^[a-zA-Z][a-zA-Z0-9]*[.:]([a-zA-Z][a-zA-Z0-9]*|[a-zA-Z][a-zA-Z0-9]*:[a-zA-Z][a-zA-Z0-9]*)$'
    if re.match(pattern, key):
        return True
    
    # Also allow nested keys like webGl:parameters
    if ':' in key or '.' in key:
        return True
    
    return False


def generate_patch_pattern_1(config: Dict) -> str:
    """Generate Pattern 1: Simple Value Override"""
    
    getter = MASKCONFIG_TYPES[config['type']]
    cpp_type = CPP_TYPES.get(config['return_type'], config['return_type'])
    
    patch = f"""diff --git a/{config['file_path']} b/{config['file_path']}
index 0000000000..1111111111 100644
--- a/{config['file_path']}
+++ b/{config['file_path']}
@@ -1,6 +1,7 @@
 #include "{config.get('existing_header', 'mozilla/dom/Something.h')}"
+#include "MaskConfig.hpp"
 
 namespace {config.get('namespace', 'mozilla::dom')} {{
 
@@ -10,6 +11,8 @@ namespace {config.get('namespace', 'mozilla::dom')} {{
 {cpp_type} {config['class_name']}::{config['method_name']}({config.get('params', '')}) {{
+  if (auto value = MaskConfig::{getter}("{config['config_key']}"))
+    return value.value();
+
   // Original implementation
   {config.get('original_code', 'return defaultValue;')}
 }}
"""
    
    # Add moz.build modification
    moz_build_path = str(Path(config['file_path']).parent / 'moz.build')
    patch += f"""
diff --git a/{moz_build_path} b/{moz_build_path}
index 0000000000..1111111111 100644
--- a/{moz_build_path}
+++ b/{moz_build_path}
@@ -100,3 +100,6 @@
 FINAL_LIBRARY = "xul"
+
+# Tegufox: Custom patch - {config['patch_name']}
+LOCAL_INCLUDES += ["/camoucfg"]
"""
    
    return patch


