def generate_patch_pattern_4(config: Dict) -> str:
    """Generate Pattern 4: Complex Structure Override"""
    
    # Determine rect type based on element type
    rect_getter = "GetRect"  # Default
    if config['element_type'] == "int32":
        rect_getter = "GetInt32Rect"
    elif config['element_type'] == "double":
        rect_getter = "GetDoubleRect"
    
    # Parse config keys
    keys = config['config_keys'].split(',')
    keys = [k.strip() for k in keys]
    
    if len(keys) != 4:
        raise ValueError("Pattern 4 requires exactly 4 config keys (e.g., left, top, width, height)")
    
    # Generate patch
    patch = f"""diff --git a/{config['file_path']} b/{config['file_path']}
index 0000000000..1111111111 100644
--- a/{config['file_path']}
+++ b/{config['file_path']}
@@ -1,6 +1,7 @@
 #include "{config.get('existing_header', 'mozilla/dom/Something.h')}"
+#include "MaskConfig.hpp"
 
 namespace {config.get('namespace', 'mozilla::dom')} {{
 
@@ -10,6 +11,15 @@ namespace {config.get('namespace', 'mozilla::dom')} {{
 {config.get('return_type', 'nsRect')} {config['class_name']}::{config['method_name']}({config.get('params', '')}) {{
+  // Tegufox: {config['patch_name']} - Complex Structure Override
+  if (auto conf = MaskConfig::{rect_getter}(
+          "{keys[0]}", 
+          "{keys[1]}",
+          "{keys[2]}", 
+          "{keys[3]}")) {{
+    auto values = conf.value();
+    {config.get('return_statement', 'return nsRect(values[0], values[1], values[2], values[3]);')}
+  }}
+
   // Original implementation
   {config.get('original_code', 'return nsRect();')}
 }}
"""
    
    # Add moz.build modification
    moz_build_path = str(Path(config['file_path']).parent / 'moz.build')
    patch += f"""
diff --git a/{moz_build_path} b/{moz_build_path}
index 0000000000..1111111111 100644
--- a/{moz_build_path}
+++ b/{moz_build_path}
@@ -100,3 +100,6 @@
 FINAL_LIBRARY = "xul"
+
+# Tegufox: Custom patch - {config['patch_name']}
+LOCAL_INCLUDES += ["/camoucfg"]
"""
    
    return patch


