+// Tegufox: Encode pseudo-headers in custom order
+void Http2Compression::EncodePseudoHeadersCustomOrder(
+    const nsTArray<nsHttpHeaderArray>& aHeaders,
+    nsACString& aOutput) {
+    
+    // Get custom pseudo-header order from MaskConfig
+    // Default: Firefox order (m,p,a,s = method, path, authority, scheme)
+    const char* custom_order = MaskConfig::GetString("http2.pseudo_header_order");
+    
+    // Parse order string (comma-separated: "method,path,authority,scheme")
+    std::vector<std::string> order;
+    
+    if (custom_order && strlen(custom_order) > 0) {
+        char* copy = strdup(custom_order);
+        char* token = strtok(copy, ",");
+        
+        while (token) {
+            // Trim whitespace
+            while (*token == ' ') token++;
+            char* end = token + strlen(token) - 1;
+            while (end > token && *end == ' ') *end-- = '\0';
+            
+            if (strlen(token) > 0) {
+                order.push_back(std::string(token));
+            }
+            
+            token = strtok(NULL, ",");
+        }
+        
+        free(copy);
+    } else {
+        // Default Firefox order: :method, :path, :authority, :scheme
+        order.push_back("method");
+        order.push_back("path");
+        order.push_back("authority");
+        order.push_back("scheme");
+    }
+    
+    // Collect pseudo-headers from input
+    std::map<std::string, std::string> pseudo_headers;
+    
+    for (const auto& header : aHeaders) {
+        nsAutoCString name;
+        header.header->GetHeader(name);
+        
+        if (name.First() == ':') {
+            // Remove ':' prefix
+            std::string key = std::string(name.BeginReading() + 1);
+            
+            nsAutoCString value;
+            header.header->GetValue(value);
+            
+            pseudo_headers[key] = std::string(value.BeginReading());
+        }
+    }
+    
+    // Encode pseudo-headers in custom order
+    for (const auto& name : order) {
+        auto it = pseudo_headers.find(name);
+        if (it != pseudo_headers.end()) {
+            nsAutoCString header_name(":");
+            header_name.Append(it->first.c_str());
+            
+            nsAutoCString header_value(it->second.c_str());
+            
+            // Encode using HPACK
+            EncodeTableSizeChange(header_name, header_value, aOutput);
+        }
+    }
+    
+    LOG3(("TEGUFOX HTTP/2 Pseudo-headers encoded in custom order\n"));
+}
