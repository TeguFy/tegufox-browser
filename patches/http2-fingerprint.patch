+// Tegufox: Send Custom WINDOW_UPDATE
+void Http2Session::SendCustomWindowUpdate() {
+    // Get custom WINDOW_UPDATE increment from MaskConfig
+    uint32_t increment = MaskConfig::GetUint32("http2.window_update", 12517377);
+    
+    if (increment == 0) {
+        LOG3(("TEGUFOX HTTP/2 WINDOW_UPDATE skipped (increment = 0)\n"));
+        return;
+    }
+    
+    // Build WINDOW_UPDATE frame (13 bytes total)
+    char frame[13];
+    
+    // Frame header (9 bytes)
+    uint32_t payloadLength = 4;
+    frame[0] = (payloadLength >> 16) & 0xFF;
+    frame[1] = (payloadLength >> 8) & 0xFF;
+    frame[2] = payloadLength & 0xFF;
+    frame[3] = 0x08;  // Type = WINDOW_UPDATE
+    frame[4] = 0x00;  // Flags = 0
+    frame[5] = 0x00;  // Stream ID = 0 (connection-level)
+    frame[6] = 0x00;
+    frame[7] = 0x00;
+    frame[8] = 0x00;
+    
+    // Payload: Window Size Increment (32-bit, MSB must be 0)
+    frame[9] = (increment >> 24) & 0x7F;  // Clear MSB (reserved bit)
+    frame[10] = (increment >> 16) & 0xFF;
+    frame[11] = (increment >> 8) & 0xFF;
+    frame[12] = increment & 0xFF;
+    
+    // Send frame
+    uint32_t count;
+    mOutputQueueSent += 13;
+    mSegmentWriter->OnWriteSegment(frame, 13, &count);
+    
+    LOG3(("TEGUFOX HTTP/2 WINDOW_UPDATE sent: increment = %u (0x%08X)\n", increment, increment));
