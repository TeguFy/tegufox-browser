+// Tegufox: Parse comma-separated list
+static void TegufoxParseList(const char* input, char** output, int* count, int max_count) {
+    if (!input || !output || !count) return;
+    
+    *count = 0;
+    char* copy = strdup(input);
+    char* token = strtok(copy, ",");
+    
+    while (token && *count < max_count) {
+        // Trim whitespace
+        while (*token == ' ') token++;
+        char* end = token + strlen(token) - 1;
+        while (end > token && *end == ' ') *end-- = '\0';
+        
+        if (strlen(token) > 0) {
+            output[*count] = strdup(token);
+            (*count)++;
+        }
+        
+        token = strtok(NULL, ",");
+    }
+    
+    free(copy);
+}
