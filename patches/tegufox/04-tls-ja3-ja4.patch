@@ -0,0 +1,73 @@
+/* -*- Mode: C; tab-width: 8; indent-tabs-mode: nil; c-basic-offset: 4 -*- */
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+/**
+ * TegufoxTLSNoise.h
+ * 
+ * Tegufox TLS JA3/JA4 Fingerprint Randomization
+ * 
+ * BUILDS ON TOP OF: Camoufox's extension permutation and GREASE support
+ * 
+ * Enhancements:
+ * 1. Domain-based cipher suite ordering (prevents cross-domain correlation)
+ * 2. Deterministic per-domain (same site = same order)
+ * 3. XXH64 domain hashing (consistent with Canvas v2 and Audio patches)
+ * 4. Fisher-Yates shuffle for cipher suite indices
+ * 
+ * Philosophy: Camoufox randomizes extensions and GREASE,
+ *             Tegufox adds domain-based cipher suite ordering on top.
+ */
+
+#ifndef tegufox_tls_noise_h__
+#define tegufox_tls_noise_h__
+
+#include <stdint.h>
+#include <stddef.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/**
+ * Generate domain-based seed for cipher suite ordering
+ * Uses XXH64 hash of domain for deterministic seeding
+ * 
+ * @param hostname - Hostname string (e.g., "example.com")
+ * @param hostnameLen - Length of hostname string
+ * @return uint64_t seed for RNG initialization (0 if error)
+ */
+uint64_t
+TegufoxTLS_GenerateDomainSeed(const char* hostname, size_t hostnameLen);
+
+/**
+ * Shuffle cipher suite indices based on domain seed
+ * Uses Fisher-Yates shuffle with PCG random generator
+ * 
+ * @param indices - Array of cipher suite indices to shuffle (in-place)
+ * @param count - Number of indices in array
+ * @param seed - Random seed (from domain hash)
+ */
+void
+TegufoxTLS_ShuffleCipherOrder(unsigned int* indices, unsigned int count, uint64_t seed);
+
+/**
+ * Extract hostname from URL string
+ * Handles various URL formats (http://, https://, bare hostname)
+ * 
+ * @param url - Full URL or hostname
+ * @param urlLen - Length of URL string
+ * @param hostname - Output buffer for hostname (caller allocated)
+ * @param hostnameMaxLen - Size of hostname buffer
+ * @return size_t - Length of extracted hostname (0 if error)
+ */
+size_t
+TegufoxTLS_ExtractHostname(const char* url, size_t urlLen, 
+                           char* hostname, size_t hostnameMaxLen);
+
+#ifdef __cplusplus
+}
+#endif
+
+#endif /* tegufox_tls_noise_h__ */
