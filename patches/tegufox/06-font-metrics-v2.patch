+/* -*- Mode: C++; tab-width: 2; indent-tabs-mode: nil; c-basic-offset: 2 -*- */
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+/*
+ * Tegufox Font Metrics v2: Per-domain deterministic font metrics perturbation
+ *
+ * Algorithm:
+ *   1. Compute seed = XXH64(domain + fontName)
+ *   2. Use PCG-XSH-RR RNG to generate per-field noise
+ *   3. Apply subtle noise to Metrics struct (±0.3px range)
+ *   4. Apply subtle noise to Baselines struct (±0.2px range)
+ *   5. Maintain internal consistency (maxHeight = maxAscent + maxDescent)
+ *
+ * Injection points:
+ *   - Canvas measureText() TextMetrics construction
+ *   - CSS ex/ch/cap/ic unit resolution via Gecko_GetFontMetrics
+ *
+ * Author: Tegufox Browser Toolkit
+ * Date: April 15, 2026
+ */
+
+#ifndef GFX_THEBES_TEGUFOX_FONT_NOISE_H_
+#define GFX_THEBES_TEGUFOX_FONT_NOISE_H_
+
+#include "gfxFont.h"
+
+namespace mozilla {
+namespace gfx {
+
+class TegufoxFontNoise {
+ public:
+  /**
+   * Apply domain-seeded noise to a copy of font Metrics.
+   * The original Metrics struct is not modified.
+   *
+   * @param aMetrics - Copy of font metrics to perturb (modified in place)
+   * @param aDomain - Domain string for seed generation (UTF-8)
+   * @param aDomainLen - Length of domain string
+   * @param aFontName - Font family name for additional seed entropy (UTF-8)
+   * @param aFontNameLen - Length of font name string
+   */
+  static void PerturbMetrics(gfxFont::Metrics& aMetrics,
+                             const char* aDomain, size_t aDomainLen,
+                             const char* aFontName, size_t aFontNameLen);
+
+  /**
+   * Apply domain-seeded noise to a copy of font Baselines.
+   * Uses the same seed derivation as PerturbMetrics for consistency.
+   *
+   * @param aBaselines - Copy of baselines to perturb (modified in place)
+   * @param aDomain - Domain string for seed generation (UTF-8)
+   * @param aDomainLen - Length of domain string
+   * @param aFontName - Font family name for additional seed entropy (UTF-8)
+   * @param aFontNameLen - Length of font name string
+   */
+  static void PerturbBaselines(gfxFont::Baselines& aBaselines,
+                               const char* aDomain, size_t aDomainLen,
+                               const char* aFontName, size_t aFontNameLen);
+
+ private:
+  // XXH64 hash for seed generation
+  static uint64_t XXH64(const char* data, size_t len, uint64_t seed);
+
+  // PCG-XSH-RR random number generator
+  struct PCGState {
+    uint64_t state;
+    uint64_t inc;
+  };
+  static uint32_t PCG_Random(PCGState& rng);
+  static PCGState PCG_Init(uint64_t seed);
+
+  // Generate a small float noise in [-range, +range]
+  static double NoiseInRange(PCGState& rng, double range);
+
+  // Combine domain and font name into a single seed
+  static uint64_t GenerateCombinedSeed(const char* aDomain, size_t aDomainLen,
+                                       const char* aFontName,
+                                       size_t aFontNameLen);
+
+  TegufoxFontNoise() = delete;
+  ~TegufoxFontNoise() = delete;
+};
+
+}  // namespace gfx
+}  // namespace mozilla
+
+#endif  // GFX_THEBES_TEGUFOX_FONT_NOISE_H_
