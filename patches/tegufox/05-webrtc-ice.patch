--- a/dom/media/webrtc/jsep/JsepSessionImpl.cpp
+++ b/dom/media/webrtc/jsep/JsepSessionImpl.cpp
@@ -2092,7 +2092,10 @@ nsresult JsepSessionImpl::CreateGenericSDP(UniquePtr<Sdp>* sdpp) {
   // "SDPARTA-", but that becomes a problem starting with version 100, since
   // some services parse 100 as "10" and give us legacy/broken behavior. So
   // we're freezing the version number at 99.0 in this string.
-  auto origin = SdpOrigin("mozilla...THIS_IS_SDPARTA-99.0", mSessionId,
+  /* TEGUFOX: Anonymize SDP origin username to prevent browser brand identification.
+   * Original: "mozilla...THIS_IS_SDPARTA-99.0" - uniquely identifies Firefox.
+   * Changed to "-" which matches the RFC recommendation and Chrome's behavior. */
+  auto origin = SdpOrigin("-", mSessionId,
                           mSessionVersion, sdp::kIPv4, "0.0.0.0");
 
   UniquePtr<Sdp> sdp = MakeUnique<SipccSdp>(origin);
@@ -2139,9 +2142,23 @@ nsresult JsepSessionImpl::SetupIds() {
     return NS_ERROR_FAILURE;
   }
 
-  if (!mUuidGen->Generate(&mCNAME)) {
-    JSEP_SET_ERROR("Failed to generate CNAME");
-    return NS_ERROR_FAILURE;
+  /* TEGUFOX: Generate CNAME as random alphanumeric string instead of UUID.
+   * Firefox uses UUID format (xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx) which
+   * is a browser-brand fingerprint. Chrome uses shorter random strings.
+   * We generate a 16-char alphanumeric CNAME instead. */
+  {
+    unsigned char cnameBytes[12];
+    rv = PK11_GenerateRandom(cnameBytes, sizeof(cnameBytes));
+    if (rv != SECSuccess) {
+      JSEP_SET_ERROR("Failed to generate CNAME");
+      return NS_ERROR_FAILURE;
+    }
+    static const char kAlphabet[] =
+        "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
+    mCNAME.clear();
+    for (size_t i = 0; i < sizeof(cnameBytes); i++) {
+      mCNAME += kAlphabet[cnameBytes[i] % 64];
+    }
   }
 
   return NS_OK;
