+      snprintf(fnd,sizeof(fnd),"%08x",hash);
+    }
     if(!(cand->foundation=r_strdup(fnd)))
       ABORT(R_NO_MEMORY);
 
@@ -550,6 +572,17 @@ int nr_ice_candidate_compute_priority(nr_ice_candidate *cand)
     assert(stun_priority < 32);
     assert(direction_priority < 8);
 
+    /* TEGUFOX: Normalize interface_preference to prevent NIC topology leakage.
+     * Original value encodes per-interface ordering (decrements for each NIC)
