@@ -0,0 +1,215 @@
+/* -*- Mode: C++; tab-width: 2; indent-tabs-mode: nil; c-basic-offset: 2 -*- */
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+#include "TegufoxCanvasNoise.h"
+
+#include <cstring>
+
+#include "js/TypeDecls.h"
+#include "mozilla/dom/Document.h"
+#include "mozilla/dom/ImageData.h"
+#include "nsContentUtils.h"
+#include "nsIURI.h"
+#include "nsNetUtil.h"
+
+namespace mozilla {
+namespace dom {
+
+// XXH64 constants
+static constexpr uint64_t PRIME64_1 = 0x9E3779B185EBCA87ULL;
+static constexpr uint64_t PRIME64_2 = 0xC2B2AE3D27D4EB4FULL;
+static constexpr uint64_t PRIME64_3 = 0x165667B19E3779F9ULL;
+static constexpr uint64_t PRIME64_4 = 0x85EBCA77C2B2AE63ULL;
+static constexpr uint64_t PRIME64_5 = 0x27D4EB2F165667C5ULL;
+
+static inline uint64_t XXH_rotl64(uint64_t x, int r) {
+  return (x << r) | (x >> (64 - r));
+}
+
+// Simplified XXH64 implementation
+uint64_t TegufoxCanvasNoise::XXH64(const char* data, size_t len,
+                                   uint64_t seed) {
+  uint64_t h64;
+
+  if (len >= 32) {
+    uint64_t v1 = seed + PRIME64_1 + PRIME64_2;
+    uint64_t v2 = seed + PRIME64_2;
+    uint64_t v3 = seed + 0;
+    uint64_t v4 = seed - PRIME64_1;
+
+    const char* end = data + len;
+    const char* limit = end - 32;
+
+    do {
+      v1 += (*reinterpret_cast<const uint64_t*>(data)) * PRIME64_2;
+      v1 = XXH_rotl64(v1, 31) * PRIME64_1;
+      data += 8;
+
+      v2 += (*reinterpret_cast<const uint64_t*>(data)) * PRIME64_2;
+      v2 = XXH_rotl64(v2, 31) * PRIME64_1;
+      data += 8;
+
+      v3 += (*reinterpret_cast<const uint64_t*>(data)) * PRIME64_2;
+      v3 = XXH_rotl64(v3, 31) * PRIME64_1;
+      data += 8;
+
+      v4 += (*reinterpret_cast<const uint64_t*>(data)) * PRIME64_2;
+      v4 = XXH_rotl64(v4, 31) * PRIME64_1;
+      data += 8;
+    } while (data <= limit);
+
+    h64 = XXH_rotl64(v1, 1) + XXH_rotl64(v2, 7) + XXH_rotl64(v3, 12) +
+          XXH_rotl64(v4, 18);
+
+    v1 *= PRIME64_2;
+    v1 = XXH_rotl64(v1, 31) * PRIME64_1;
+    h64 ^= v1;
+    h64 = h64 * PRIME64_1 + PRIME64_4;
+
+    v2 *= PRIME64_2;
+    v2 = XXH_rotl64(v2, 31) * PRIME64_1;
+    h64 ^= v2;
+    h64 = h64 * PRIME64_1 + PRIME64_4;
+
+    v3 *= PRIME64_2;
+    v3 = XXH_rotl64(v3, 31) * PRIME64_1;
+    h64 ^= v3;
+    h64 = h64 * PRIME64_1 + PRIME64_4;
+
+    v4 *= PRIME64_2;
+    v4 = XXH_rotl64(v4, 31) * PRIME64_1;
+    h64 ^= v4;
+    h64 = h64 * PRIME64_1 + PRIME64_4;
+
+  } else {
+    h64 = seed + PRIME64_5;
+  }
+
+  h64 += len;
+
+  // Finalization
+  h64 ^= h64 >> 33;
+  h64 *= PRIME64_2;
+  h64 ^= h64 >> 29;
+  h64 *= PRIME64_3;
+  h64 ^= h64 >> 32;
+
+  return h64;
+}
+
+uint64_t TegufoxCanvasNoise::GenerateDomainSeed(const nsAString& aDomain) {
+  // Convert nsAString to UTF-8 C string
+  NS_ConvertUTF16toUTF8 utf8Domain(aDomain);
+  const char* domainCStr = utf8Domain.get();
+  size_t domainLen = utf8Domain.Length();
+
+  // Generate XXH64 hash with seed 0
+  uint64_t seed = XXH64(domainCStr, domainLen, 0);
+  return seed;
+}
+
+void TegufoxCanvasNoise::InjectNoise(ImageData* aImageData, uint64_t aSeed,
+                                     float aNoiseStdDev) {
+  if (!aImageData) {
+    return;
+  }
+
+  // Get ImageData buffer
+  JSObject* dataObj = aImageData->GetDataObject();
+  if (!dataObj) {
+    return;
+  }
+
+  uint32_t length = aImageData->Width() * aImageData->Height() * 4;
+  
+  // Access typed array data with AutoCheckCannotGC
+  JS::AutoCheckCannotGC nogc;
+  bool isShared = false;
+  uint8_t* data = JS_GetUint8ClampedArrayData(dataObj, &isShared, nogc);
+  if (!data) {
+    return;
+  }
+
+  // Initialize random number generator with domain seed
+  // NOTE: We use domain-only seed for anti-fingerprinting. Each session gets
+  // a unique canvas fingerprint that cannot be correlated across page loads,
+  // preventing tracker identification while maintaining deterministic behavior
+  // within the same browser session.
+  std::mt19937_64 rng(aSeed);
+  std::normal_distribution<float> dist(0.0f, aNoiseStdDev);
+
+  // Inject noise into RGB channels only (preserve Alpha)
+  for (uint32_t i = 0; i < length; i += 4) {
+    // Red channel
+    float noiseR = dist(rng);
+    data[i] = Clamp(static_cast<float>(data[i]) + noiseR, 0.0f, 255.0f);
+
+    // Green channel
+    float noiseG = dist(rng);
+    data[i + 1] =
+        Clamp(static_cast<float>(data[i + 1]) + noiseG, 0.0f, 255.0f);
+
+    // Blue channel
+    float noiseB = dist(rng);
+    data[i + 2] =
+        Clamp(static_cast<float>(data[i + 2]) + noiseB, 0.0f, 255.0f);
+
+    // Alpha channel (i + 3) - DO NOT MODIFY
+  }
+}
+
+void TegufoxCanvasNoise::InjectNoiseToBGRABuffer(uint8_t* aData,
+                                                  uint32_t aNumPixels,
+                                                  uint64_t aSeed) {
+  if (!aData || aNumPixels == 0) return;
+
+  std::mt19937_64 rng(aSeed);
+  std::normal_distribution<float> dist(0.0f, 2.0f);
+
+  // BGRA format (B=i, G=i+1, R=i+2, A=i+3)
+  for (uint32_t i = 0; i < aNumPixels * 4; i += 4) {
+    float n0 = dist(rng);
+    aData[i]     = Clamp(static_cast<float>(aData[i])     + n0, 0.0f, 255.0f);
+    float n1 = dist(rng);
+    aData[i + 1] = Clamp(static_cast<float>(aData[i + 1]) + n1, 0.0f, 255.0f);
+    float n2 = dist(rng);
+    aData[i + 2] = Clamp(static_cast<float>(aData[i + 2]) + n2, 0.0f, 255.0f);
+    // Alpha (i+3) — preserve
+  }
+}
+
+bool TegufoxCanvasNoise::ExtractDomain(Document* aDocument,
+                                        nsAString& aDomain) {
+  if (!aDocument) {
+    return false;
+  }
+
+  // Get document URI
+  nsIURI* uri = aDocument->GetDocumentURI();
+  if (!uri) {
+    return false;
+  }
+
+  // Get host from URI (e.g., "www.example.com")
+  nsAutoCString host;
+  nsresult rv = uri->GetHost(host);
+  
+  // For file:// URIs, use spec (full path) as domain
+  if (!NS_SUCCEEDED(rv) || host.IsEmpty()) {
+    nsAutoCString spec;
+    rv = uri->GetSpec(spec);
+    if (NS_SUCCEEDED(rv) && !spec.IsEmpty()) {
+      CopyUTF8toUTF16(spec, aDomain);
+      return true;
+    }
+    return false;
+  }
+  
+  CopyUTF8toUTF16(host, aDomain);
+  return true;
+}
+
+}  // namespace dom
+}  // namespace mozilla
