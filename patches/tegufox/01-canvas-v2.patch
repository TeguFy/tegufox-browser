+/* -*- Mode: C++; tab-width: 2; indent-tabs-mode: nil; c-basic-offset: 2 -*- */
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+/*
+ * Tegufox Canvas v2: Per-domain deterministic canvas noise injection
+ * 
+ * Algorithm:
+ *   1. Extract domain from document URI
+ *   2. Generate 64-bit seed using XXH64 hash of domain
+ *   3. Inject Gaussian noise with domain seed into canvas ImageData
+ *   4. Preserve Alpha channel (only modify RGB)
+ *
+ * Performance target: < 5% overhead on GetImageData()
+ * 
+ * Author: Tegufox Browser Toolkit
+ * Date: April 14, 2026
+ */
+
+#ifndef DOM_CANVAS_TEGUFOX_CANVAS_NOISE_H_
+#define DOM_CANVAS_TEGUFOX_CANVAS_NOISE_H_
+
+#include <cstdint>
+#include <random>
+
+#include "nsString.h"
+
+namespace mozilla {
+
+namespace dom {
+class Document;
+class ImageData;
+}  // namespace dom
+
+namespace dom {
+
+class TegufoxCanvasNoise {
+ public:
+  /**
+   * Generate a deterministic 64-bit seed from a domain string
+   * Uses XXH64 hash algorithm for fast, collision-resistant hashing
+   * 
+   * @param aDomain - Domain name (e.g., "example.com")
+   * @return 64-bit seed value
+   */
+  static uint64_t GenerateDomainSeed(const nsAString& aDomain);
+
+  /**
+   * Inject Gaussian noise into ImageData based on domain seed
+   * 
+   * @param aImageData - ImageData to modify (RGB channels only)
+   * @param aSeed - 64-bit seed for reproducible noise
+   * @param aNoiseStdDev - Standard deviation for Gaussian noise (default: 2.0)
+   */
+  static void InjectNoise(ImageData* aImageData, uint64_t aSeed,
+                          float aNoiseStdDev = 2.0);
+
+  // Apply noise directly to a raw BGRA pixel buffer (used by toDataURL/toBlob)
+  static void InjectNoiseToBGRABuffer(uint8_t* aData, uint32_t aNumPixels,
+                                      uint64_t aSeed);
+
+  /**
+   * Extract domain from document URI
+   * Falls back to full host if domain not available
+   * 
+   * @param aDocument - Document to extract domain from
+   * @param aDomain - Output parameter for domain string
+   * @return true if domain extracted successfully
+   */
+  static bool ExtractDomain(Document* aDocument, nsAString& aDomain);
+
+ private:
+  /**
+   * XXH64 hash implementation (simplified)
+   * See: https://github.com/Cyan4973/xxHash
+   */
+  static uint64_t XXH64(const char* data, size_t len, uint64_t seed);
+
+  /**
+   * Clamp value to [min, max] range
+   */
+  static inline uint8_t Clamp(float value, float min, float max) {
+    if (value < min) return static_cast<uint8_t>(min);
+    if (value > max) return static_cast<uint8_t>(max);
+    return static_cast<uint8_t>(value);
+  }
+
+  TegufoxCanvasNoise() = delete;
+  ~TegufoxCanvasNoise() = delete;
+};
+
+}  // namespace dom
+}  // namespace mozilla
+
+#endif  // DOM_CANVAS_TEGUFOX_CANVAS_NOISE_H_
