+const TegufoxGPUProfile* TegufoxGPUProfiles::FindProfile(
+    const std::string& vendor, const std::string& renderer) {
+  const auto& profiles = GetProfiles();
+  
+  // Try exact match first
+  for (const auto& profile : profiles) {
+    if (profile.vendor == vendor && profile.renderer == renderer) {
+      return &profile;
+    }
+  }
+  
+  // Try partial match
+  for (const auto& profile : profiles) {
+    if (profile.IsVendorMatch(vendor) && profile.IsRendererMatch(renderer)) {
+      return &profile;
+    }
+  }
+  
+  return nullptr;
+}
+
+const TegufoxGPUProfile& TegufoxGPUProfiles::GetRandomProfile() {
+  const auto& profiles = GetProfiles();
+  static std::random_device rd;
+  static std::mt19937 gen(rd());
+  std::uniform_int_distribution<size_t> dist(0, profiles.size() - 1);
+  return profiles[dist(gen)];
+}
+
+bool TegufoxGPUProfiles::ValidateConsistency(const std::string& vendor,
+                                              const std::string& renderer) {
+  // Check for obvious mismatches
+  std::string vendorLower = ToLower(vendor);
+  std::string rendererLower = ToLower(renderer);
+  
+  // NVIDIA vendor should have NVIDIA renderer
+  if (ContainsIgnoreCase(vendorLower, "nvidia") && 
+      !ContainsIgnoreCase(rendererLower, "nvidia")) {
+    return false;
+  }
+  
+  // Intel vendor should have Intel renderer
+  if (ContainsIgnoreCase(vendorLower, "intel") && 
+      !ContainsIgnoreCase(rendererLower, "intel")) {
+    return false;
+  }
+  
+  // AMD vendor should have AMD renderer
+  if (ContainsIgnoreCase(vendorLower, "amd") && 
+      !ContainsIgnoreCase(rendererLower, "amd")) {
+    return false;
+  }
+  
+  // Apple vendor should have Apple renderer
+  if (ContainsIgnoreCase(vendorLower, "apple") && 
+      !ContainsIgnoreCase(rendererLower, "apple")) {
+    return false;
+  }
+  
+  // If we have a known profile, it's consistent
+  return FindProfile(vendor, renderer) != nullptr;
+}
+
+const std::vector<TegufoxGPUProfile>& TegufoxGPUProfiles::GetAllProfiles() {
+  return GetProfiles();
+}
+
+// ----- Helper Functions -----
+
+bool TegufoxGPUProfiles::ContainsIgnoreCase(const std::string& haystack,
+                                             const std::string& needle) {
+  return ToLower(haystack).find(ToLower(needle)) != std::string::npos;
+}
