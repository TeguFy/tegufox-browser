+
+static std::string ToLowerHelper(const std::string& str) {
+  std::string result = str;
+  std::transform(result.begin(), result.end(), result.begin(),
+                 [](unsigned char c) { return std::tolower(c); });
+  return result;
+}
+
+// ----- TegufoxGPUProfile Member Functions -----
+
+bool TegufoxGPUProfile::IsVendorMatch(const std::string& vendorQuery) const {
+  std::string vendorLower = ToLowerHelper(vendor);
+  std::string queryLower = ToLowerHelper(vendorQuery);
+  return vendorLower.find(queryLower) != std::string::npos ||
+         queryLower.find(vendorLower) != std::string::npos;
+}
+
+bool TegufoxGPUProfile::IsRendererMatch(const std::string& rendererQuery) const {
+  std::string rendererLower = ToLowerHelper(renderer);
+  std::string queryLower = ToLowerHelper(rendererQuery);
+  return rendererLower.find(queryLower) != std::string::npos ||
+         queryLower.find(rendererLower) != std::string::npos;
+}
+
+bool TegufoxGPUProfile::HasExtension(const std::string& extension) const {
+  return std::find(extensions.begin(), extensions.end(), extension) != extensions.end();
+}
