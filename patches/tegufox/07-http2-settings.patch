+        token.Assign(Substring(orderStr, start, end - start));
+        token.StripWhitespace();
+
+        if (token.EqualsLiteral("m") && !sentMethod) {
+          ProcessHeader(nvPair(":method"_ns, method), false, false);
+          sentMethod = true;
+        } else if (token.EqualsLiteral("p") && !sentPath) {
+          ProcessHeader(nvPair(":path"_ns, path), true, false);
+          sentPath = true;
+        } else if (token.EqualsLiteral("a") && !sentAuthority) {
+          ProcessHeader(nvPair(":authority"_ns, host), false, false);
+          sentAuthority = true;
+        } else if (token.EqualsLiteral("s") && !sentScheme) {
+          ProcessHeader(nvPair(":scheme"_ns, scheme), false, false);
+          sentScheme = true;
+        }
