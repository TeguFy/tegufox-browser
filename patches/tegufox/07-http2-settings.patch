+    auto pseudoOrder = MaskConfig::GetString("http2:pseudo_header_order");
+    if (pseudoOrder) {
+      // Parse comma-separated order string (e.g., "m,a,s,p")
+      nsAutoCString orderStr(pseudoOrder.value().c_str());
+      bool sentMethod = false, sentPath = false, sentAuthority = false,
+           sentScheme = false;
+      int32_t start = 0;
+      int32_t commaPos;
+      while (start < (int32_t)orderStr.Length()) {
+        commaPos = orderStr.Find(",", start);
+        int32_t end = (commaPos == -1) ? (int32_t)orderStr.Length() : commaPos;
