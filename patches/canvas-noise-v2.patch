+// ============================================================================
+// TEGUFOX CANVAS NOISE V2 - GPU-SIMULATED RENDERING VARIANCE
+// ============================================================================
+// Advanced canvas fingerprint defense using GPU-realistic noise injection
+// 
+// Design principles:
+// - Per-origin, per-session seeding (stable within session)
+// - GPU-correlated noise patterns (mimics real hardware variance)
+// - Sub-pixel intensity (±1-2 on <0.1% of pixels, imperceptible)
+// - Native C++ implementation (no JS prototype tampering)
+//
+// MaskConfig parameters:
+//   canvas:seed              - Base seed (uint32)
+//   canvas:noise:enable      - Master switch (bool, default: true)
+//   canvas:noise:strategy    - Algorithm: "gpu" | "temporal" | "hybrid"
+//   canvas:noise:intensity   - Pixel coverage % (default: 0.0001 = 0.01%)
+//   canvas:noise:magnitude   - Max ±value (1-3, default: 2)
+//   canvas:noise:edge-bias   - Extra noise near edges (default: 0.0004)
+//   canvas:noise:temporal    - Time-based micro-variance (bool, default: true)
+// ============================================================================
+
+namespace {
+
+// Fast hash function for noise generation (deterministic, not cryptographic)
+inline uint64_t FastHash64(uint64_t x, uint64_t y, uint64_t seed) {
+  // xxHash-inspired mixing function
+  constexpr uint64_t PRIME1 = 0x9E3779B185EBCA87ULL;
+  constexpr uint64_t PRIME2 = 0xC2B2AE3D27D4EB4FULL;
+  constexpr uint64_t PRIME3 = 0x165667B19E3779F9ULL;
+  
+  uint64_t h = seed + PRIME1;
+  h ^= x * PRIME2;
+  h = ((h << 31) | (h >> 33)) * PRIME3;
+  h ^= y * PRIME2;
+  h = ((h << 31) | (h >> 33)) * PRIME3;
+  
+  return h;
+}
+
+// Spatial hash for GPU-like rendering artifacts
+inline uint64_t SpatialHash(int x, int y, uint64_t seed) {
+  // Create spatial coherence (nearby pixels use similar seeds)
+  // This simulates GPU block processing patterns
+  int blockX = x / 8;  // 8x8 blocks (typical GPU tile size)
+  int blockY = y / 8;
+  
+  return FastHash64(static_cast<uint64_t>(blockX), 
+                    static_cast<uint64_t>(blockY), 
+                    seed);
+}
+
+// Simple edge detection (gradient magnitude)
+// Returns distance from nearest edge (0 = on edge, >2 = interior)
+inline float DetectEdgeDistance(const uint8_t* imageData, int width, int height, 
+                                int x, int y) {
+  if (x <= 1 || x >= width - 2 || y <= 1 || y >= height - 2) {
+    return 0.0f;  // Image border = edge
+  }
+  
+  // Sobel operator for edge detection
+  int idx = (y * width + x) * 4;
+  
+  // Horizontal gradient
+  int gx = -1 * imageData[idx - 4] + 1 * imageData[idx + 4];
+  
+  // Vertical gradient  
+  int gy = -1 * imageData[idx - width * 4] + 1 * imageData[idx + width * 4];
+  
+  // Gradient magnitude
+  float gradient = sqrt(gx * gx + gy * gy);
+  
+  // Convert to distance (higher gradient = closer to edge)
+  if (gradient > 50) return 0.0f;   // Strong edge
+  if (gradient > 20) return 1.0f;   // Weak edge
+  return 3.0f;                       // Interior
+}
+
+// Generate per-origin, per-session seed
+uint64_t GenerateCanvasSeed(nsIPrincipal* principal) {
+  // Start with MaskConfig base seed
+  uint64_t baseSeed = MaskConfig::GetUint32("canvas:seed").value_or(0);
+  
+  if (!principal) {
+    return baseSeed;
+  }
+  
+  // Hash origin URI for per-origin isolation
+  nsCString origin;
+  if (NS_SUCCEEDED(principal->GetOriginNoSuffix(origin))) {
+    uint64_t originHash = 0;
+    for (char c : origin) {
+      originHash = originHash * 31 + static_cast<uint8_t>(c);
+    }
+    baseSeed ^= originHash;
+  }
+  
+  // Add temporal component if enabled
+  if (MaskConfig::CheckBool("canvas:noise:temporal")) {
+    // Change seed every ~100ms, but only affect lower 8 bits
+    // This creates micro-variance within same fingerprint "bucket"
+    uint64_t timestamp = PR_Now() / (100 * PR_USEC_PER_MSEC);  // 100ms buckets
+    baseSeed ^= (timestamp & 0xFF);
+  }
+  
+  return baseSeed;
+}
+
+// Determine if pixel should receive noise
+bool ShouldNoisePixel(const uint8_t* imageData, int width, int height,
+                      int x, int y, uint64_t seed) {
+  // Spatial hash for deterministic selection
+  uint64_t hash = SpatialHash(x, y, seed);
+  
+  // Base intensity from config (default: 0.0001 = 0.01% of pixels)
+  double intensity = MaskConfig::GetDouble("canvas:noise:intensity").value_or(0.0001);
+  
+  // Edge bias: extra noise near edges (anti-aliasing variance)
+  float edgeDistance = DetectEdgeDistance(imageData, width, height, x, y);
+  double edgeBias = MaskConfig::GetDouble("canvas:noise:edge-bias").value_or(0.0004);
+  
+  if (edgeDistance < 2.0f) {
+    intensity += edgeBias;
+  }
+  
+  // Convert to threshold (0.0001 = 1 in 10,000)
+  uint64_t threshold = static_cast<uint64_t>(intensity * 1000000.0);
+  
+  return (hash % 1000000) < threshold;
+}
+
+// Get noise value for pixel channel
+int8_t GetNoiseValue(int x, int y, int channel, uint64_t seed) {
+  uint64_t hash = FastHash64(static_cast<uint64_t>(x), 
+                             static_cast<uint64_t>(y * 3 + channel), 
+                             seed);
+  
+  // Magnitude from config (default: 2 = ±1 or ±2)
+  int32_t magnitude = MaskConfig::GetInt32("canvas:noise:magnitude").value_or(2);
+  magnitude = std::clamp(magnitude, 1, 3);  // Clamp to safe range
+  
+  // Generate noise value: ±1, ±2, or ±3 (never 0)
+  int8_t values[] = {-magnitude, -magnitude + 1, magnitude - 1, magnitude};
+  return values[hash % 4];
+}
+
+// Apply noise to single pixel (RGB channels, preserve alpha)
+void ApplyNoiseToPixel(uint8_t* pixel, int x, int y, uint64_t seed) {
+  // Channel-correlated noise (GPU processes RGB together)
+  uint64_t channelSeed = FastHash64(static_cast<uint64_t>(x), 
+                                    static_cast<uint64_t>(y), 
+                                    seed);
+  
+  // Red channel
+  int16_t r = pixel[0] + GetNoiseValue(x, y, 0, channelSeed);
+  pixel[0] = static_cast<uint8_t>(std::clamp(r, 0, 255));
+  
+  // Green channel
+  int16_t g = pixel[1] + GetNoiseValue(x, y, 1, channelSeed);
+  pixel[1] = static_cast<uint8_t>(std::clamp(g, 0, 255));
+  
+  // Blue channel
+  int16_t b = pixel[2] + GetNoiseValue(x, y, 2, channelSeed);
+  pixel[2] = static_cast<uint8_t>(std::clamp(b, 0, 255));
+  
+  // Alpha channel: NEVER modify (breaks transparency)
+  // pixel[3] = unchanged
+}
+
+// Main noise application function
+void ApplyCanvasNoise(uint8_t* imageData, int width, int height, 
+                      nsIPrincipal* principal) {
+  // Check if noise is enabled
+  if (!MaskConfig::CheckBool("canvas:noise:enable")) {
+    return;
+  }
+  
+  // Generate seed for this canvas operation
+  uint64_t seed = GenerateCanvasSeed(principal);
+  
+  // Get strategy (default: "gpu")
+  std::string strategy = MaskConfig::GetString("canvas:noise:strategy")
+                            .value_or("gpu");
+  
+  // Strategy selection
+  if (strategy == "temporal") {
+    // Pure temporal variance (changes over time)
+    // Useful for defeating "multiple renders = identical hash" detection
+    seed ^= (PR_Now() / PR_USEC_PER_MSEC);
+  } 
+  else if (strategy == "hybrid") {
+    // Combine GPU simulation with temporal variance
+    // Most realistic behavior (GPU rendering has tiny time variations)
+    seed ^= (PR_Now() / (50 * PR_USEC_PER_MSEC));  // 50ms buckets
+  }
+  // else "gpu" - use base seed (default behavior)
+  
+  // Apply noise to selected pixels
+  for (int y = 0; y < height; y++) {
+    for (int x = 0; x < width; x++) {
+      if (ShouldNoisePixel(imageData, width, height, x, y, seed)) {
+        int idx = (y * width + x) * 4;  // RGBA format
+        ApplyNoiseToPixel(&imageData[idx], x, y, seed);
+      }
+    }
+  }
+}
+
+}  // anonymous namespace
